@using System.Text.Json
@using Microsoft.Extensions.Localization
@model MovieMvcProject.Web.Models.MovieDetailViewModel
@inject IStringLocalizer<MovieMvcProject.Domain.Resources.MovieResource> MovieLocalizer

@{
    Layout = "_Layout";
    var movie = Model.MovieDetail;
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <link rel="stylesheet" href="~/css/moviedetail/movie-details.css" />
}

<main class="min-h-screen bg-[#0f121d] text-white font-sans pb-20">
    <form id="globalCsrfForm" style="display:none;">
        @Html.AntiForgeryToken()
    </form>

    <div class="relative h-[500px] w-full overflow-hidden">
        <img src="@movie?.PosterUrl" class="w-full h-full object-cover blur-3xl opacity-30" />
        <div class="absolute inset-0 bg-gradient-to-t from-[#0f121d] via-[#0f121d]/50 to-transparent"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 md:px-10 -mt-80 relative z-10">
        <partial name="MovieDetails/_MovieHeaderPartial" model="Model" />

        <partial name="MovieDetails/_MovieActorsPartial" model="Model" />

        <partial name="MovieDetails/_MovieCommentsPartial" model="Model" />
    </div>
</main>

<partial name="MovieDetails/_MovieModalsPartial" model="Model" />

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <script src="~/js/moviedetail/movie-details.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", () => {
        const config = {
        movieId: '@movie?.MovieId',
        trailerUrl: '@movie?.VideoUrl',
        localizer: {
        commentLoadError: @Html.Raw(JsonSerializer.Serialize(MovieLocalizer["CommentLoadError"].Value)),
        replyTitle: @Html.Raw(JsonSerializer.Serialize(MovieLocalizer["ReplyTitle"].Value)),
        replyingToText: @Html.Raw(JsonSerializer.Serialize(MovieLocalizer["ReplyingToText"].Value)),
        cancel: @Html.Raw(JsonSerializer.Serialize(MovieLocalizer["CancelButton"].Value)),
        send: @Html.Raw(JsonSerializer.Serialize(MovieLocalizer["SendButton"].Value)),
        deleteTitle: @Html.Raw(JsonSerializer.Serialize(MovieLocalizer["DeleteCommentTitle"].Value)),
        deleteConfirm: @Html.Raw(JsonSerializer.Serialize(MovieLocalizer["DeleteConfirmText"].Value)),
        yesDelete: @Html.Raw(JsonSerializer.Serialize(MovieLocalizer["YesDeleteButton"].Value)),
        loginToComment: @Html.Raw(JsonSerializer.Serialize(MovieLocalizer["LoginToComment"].Value))
        }
        };
            
        initMovieDetails(config);
        });
    </script>
}