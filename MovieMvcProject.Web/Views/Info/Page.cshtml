@using Microsoft.Extensions.Localization
@using MovieMvcProject.Domain.Resources
@inject IStringLocalizer<StaticPagesResource> Localizer
@{
    Layout = "_Layout";
    string slug = ViewData["Slug"]?.ToString() ?? "About";
    string localizedTitle = Localizer[slug].Value;
    ViewData["Title"] = localizedTitle;

    
    var titleWords = localizedTitle.Split(' ');
    string firstWord = titleWords[0];
    string remainingWords = string.Join(' ', titleWords.Skip(1));
}

<div class="relative overflow-hidden min-h-[80vh] flex flex-col items-center justify-start pt-20 pb-20">
    @* Arka Plan Dekoratif Işığı *@
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-4xl h-[400px] bg-primary/10 blur-[120px] rounded-full pointer-events-none"></div>

    <div class="relative z-10 w-full max-w-4xl px-6">
        
        <nav class="flex items-center gap-2 text-[11px] font-black uppercase tracking-[0.2em] text-gray-500 mb-6">
            <a asp-controller="Movie" asp-action="Index" class="hover:text-primary transition-colors">@Localizer["Home"]</a>
            <span class="material-symbols-outlined !text-xs">chevron_right</span>
            <span class="text-primary">@localizedTitle</span>
        </nav>

        @* Sayfa Başlığı - Dinamik Renklendirme *@
        <div class="mb-12">
            <h1 class="text-5xl md:text-7xl font-black text-white tracking-tighter uppercase italic leading-none">
                @firstWord<br />
                <span class="text-primary">@remainingWords</span>
            </h1>
            <div class="h-1.5 w-24 bg-primary mt-8 rounded-full"></div>
        </div>

        @* İçerik Kartı *@
        <div class="relative group">
            <div class="absolute -inset-1 bg-gradient-to-b from-primary/20 to-transparent rounded-[2.5rem] blur opacity-25 group-hover:opacity-50 transition duration-1000"></div>

            <div class="relative bg-card-dark/60 backdrop-blur-xl border border-white/5 rounded-[2.5rem] p-8 md:p-16 shadow-2xl">
                <div class="prose prose-invert prose-p:text-gray-400 prose-p:leading-relaxed prose-p:text-lg prose-strong:text-white max-w-none">
                    @Html.Raw(Localizer[slug + "Content"])
                </div>

                @* Alt Alan - Keşfetmeye Dön Butonu  *@
                <div class="mt-16 pt-8 border-t border-white/5 flex justify-end">
                    <a asp-controller="Movie" asp-action="Index" class="flex items-center gap-2 text-xs font-black uppercase tracking-tighter bg-white/5 hover:bg-primary px-8 py-4 rounded-2xl transition-all group/btn">
                        <span class="material-symbols-outlined !text-sm group-hover:-translate-x-1 transition-transform">arrow_back</span>
                        @Localizer["BackToDiscovery"]
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>