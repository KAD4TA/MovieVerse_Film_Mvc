@model MovieMvcProject.Web.Models.WishlistViewModel
@using Microsoft.Extensions.Localization
@using MovieMvcProject.Domain.Resources
@inject IStringLocalizer<EnumResource> EnumLocalizer
@inject IStringLocalizer<WishlistResource> Localizer

@{
    var movie = Model.Movie;
}

@if (movie != null)
{
    <div class="group flex flex-col relative wishlist-item" id="wishlist-item-@movie.MovieId">
        <button type="button" onclick="removeFromWishlist('@movie.MovieId')" title="@Localizer["RemoveFromList"]"
                class="absolute top-3 right-3 z-20 opacity-0 group-hover:opacity-100 w-9 h-9 flex items-center justify-center rounded-full bg-red-600 hover:bg-red-700 text-white shadow-lg transition">
            <span class="material-symbols-outlined text-sm">close</span>
        </button>

        <a asp-controller="Movie" asp-action="MovieDetail" asp-route-id="@movie.MovieId" class="relative block">
            <div class="relative overflow-hidden rounded-2xl aspect-[2/3] shadow-xl border border-white/5 bg-gray-900">
                <img src="@(string.IsNullOrEmpty(movie.PosterUrl) ? "/images/default-poster.jpg" : movie.PosterUrl)"
                     alt="@movie.Title"
                     class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                     onerror="this.src='/images/default-poster.jpg'" />
                
                <div class="absolute inset-0 bg-gradient-to-t from-blue-900/90 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end justify-center pb-6">
                    <span class="bg-white text-blue-900 text-[10px] font-black px-4 py-2 rounded-full transform translate-y-4 group-hover:translate-y-0 transition-transform uppercase">
                        @Localizer["ViewDetails"]
                    </span>
                </div>
            </div>

            <div class="mt-4 space-y-1">
                <h4 class="font-bold text-white text-sm md:text-base leading-tight line-clamp-2 group-hover:text-blue-400 transition-colors">
                    @(string.IsNullOrWhiteSpace(movie.Title) ? Localizer["UntitledMovie"] : movie.Title)
                </h4>
                <div class="flex items-center justify-between">
                    <span class="text-[10px] text-blue-500 font-black uppercase">
                        @EnumLocalizer[$"Category_{movie.Category}"]
                    </span>
                    <span class="text-[10px] text-gray-500 font-bold">@movie.Year</span>
                </div>
                <div class="flex items-center justify-between mt-1">
                    <div class="flex items-center gap-1">
                        <span class="text-yellow-500 text-xs">★</span>
                        <span class="text-[10px] text-gray-400 font-bold">@movie.Rating.ToString("F1")</span>
                    </div>
                    <span class="text-[10px] text-gray-500 font-medium italic">
                        @Model.AddedAt.ToString("dd MMM yyyy")
                    </span>
                </div>
            </div>
        </a>
    </div>
}