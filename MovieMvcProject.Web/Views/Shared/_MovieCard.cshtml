
@model MovieMvcProject.Application.DTOs.ResponseDto.MovieDtoResponse


<div class="min-w-[160px] md:min-w-[200px] w-[160px] md:w-[200px] group flex flex-col h-full rounded-xl transition-transform duration-300 hover:scale-[1.02]">

   
    <div class="relative aspect-[2/3] rounded-xl overflow-hidden shadow-lg border border-gray-800 bg-gray-900">

       
        <a asp-controller="Movie" asp-action="MovieDetail" asp-route-id="@Model.MovieId" class="block w-full h-full">
            @if (!string.IsNullOrEmpty(Model.PosterUrl))
            {
                <img src="@Model.PosterUrl"
                     alt="@Model.Title"
                     loading="lazy"
                     class="w-full h-full object-cover transition-opacity duration-300 group-hover:opacity-90" />
            }
            else
            {
                <div class="flex items-center justify-center w-full h-full bg-gray-800 text-gray-500">
                    <span class="material-symbols-outlined text-4xl">movie</span>
                </div>
            }
        </a>

        
        @if (!string.IsNullOrEmpty(Model.Category))
        {
            <div class="absolute top-2 right-2 z-10">
                <span class="bg-primary/90 backdrop-blur-md text-white text-[10px] font-bold px-2 py-1 rounded shadow-sm uppercase tracking-wider">
                    @Model.Category
                </span>
            </div>
        }
    </div>

    
    <div class="mt-3 flex flex-col px-1">

        @* Başlık *@
        <h3 class="text-gray-100 font-bold text-sm md:text-base truncate group-hover:text-primary transition-colors">
            <a asp-controller="Movie" asp-action="MovieDetail" asp-route-id="@Model.MovieId" title="@Model.Title">
                @Model.Title
            </a>
        </h3>

        @* Yıl Bilgisi *@
        <span class="text-gray-500 text-xs font-medium mt-0.5">@Model.Year</span>

        
        <div class="flex items-center gap-2 mt-1">
            <div class="flex text-yellow-400">
                @for (int i = 1; i <= 5; i++)
                {
                    // Yıldız Doluluk Mantığı
                    var isFilled = (Model.Rating / 2) >= i;
                    <span class="material-symbols-outlined text-[16px] @(isFilled ? "fill-1" : "text-gray-700")">
                        star
                    </span>
                }
            </div>
            <span class="text-gray-300 text-xs font-bold">@Model.Rating.ToString("0.0")</span>
        </div>
    </div>

</div>