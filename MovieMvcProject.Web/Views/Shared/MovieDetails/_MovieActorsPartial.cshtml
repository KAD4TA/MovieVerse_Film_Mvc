@using Microsoft.Extensions.Localization
@model MovieMvcProject.Web.Models.MovieDetailViewModel
@inject IStringLocalizer<MovieMvcProject.Domain.Resources.MovieResource> MovieLocalizer

<div class="mt-24">
    <h3 class="text-2xl font-black mb-8 italic flex items-center gap-3 tracking-tight">
        <span class="w-1.5 h-8 bg-blue-600 rounded-full"></span> @MovieLocalizer["ActorsHeader"].Value
    </h3>
    <div class="grid grid-cols-2 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-7 gap-6">
        @foreach (var actor in Model.Actors)
        {
            <div class="group text-center">
                <a asp-controller="Actors" asp-action="Details" asp-route-id="@actor.ActorId">
                    <div class="w-24 h-24 mx-auto rounded-full overflow-hidden border-2 border-white/5 group-hover:border-blue-500 transition-all duration-300 mb-4 shadow-xl">
                        <img src="@actor.ProfilePictureUrl" class="w-full h-full object-cover" onerror="this.src='/profile-images/default-profile.png'" />
                    </div>
                    <h5 class="text-sm font-bold truncate px-2 group-hover:text-blue-500 transition-colors">@actor.ActorName</h5>
                </a>
                <p class="text-[10px] text-gray-500 font-bold uppercase mt-1">@MovieLocalizer["actor"]</p>
            </div>
        }
    </div>
</div>