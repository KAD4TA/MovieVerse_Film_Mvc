@using System.Security.Claims
@using Microsoft.Extensions.Localization
@model MovieMvcProject.Web.Models.MovieDetailViewModel
@inject IStringLocalizer<MovieMvcProject.Domain.Resources.MovieResource> MovieLocalizer

@{
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    var movie = Model.MovieDetail;
}

<div class="mt-32 border-t border-white/5 pt-16" id="comments-anchor">
    <h3 class="text-3xl font-black italic mb-10 flex items-center gap-3">
        <span class="material-symbols-outlined text-4xl text-blue-500">forum</span> @MovieLocalizer["UserCommentsHeader"].Value
    </h3>
    @if (isAuthenticated)
    {
        <form id="mainCommentForm" class="glass-card p-8 rounded-[2rem] mb-16 shadow-2xl relative overflow-hidden">
            <div class="absolute top-0 left-0 w-1 h-full bg-blue-600"></div>
            @Html.AntiForgeryToken()
            <input type="hidden" name="MovieId" value="@movie?.MovieId" />
            <input type="hidden" name="ParentId" value="" />
            <div class="flex flex-col gap-6">
                <textarea name="Content" rows="3" required placeholder="@MovieLocalizer["CommentPlaceholder"].Value"
                          class="w-full bg-black/30 border border-white/10 rounded-2xl p-5 text-white placeholder-gray-500 focus:border-blue-500 focus:bg-black/50 outline-none transition-all resize-none text-lg"></textarea>
                <div class="flex flex-wrap justify-between items-center gap-4">
                    <div class="flex items-center gap-4 bg-black/40 px-5 py-2.5 rounded-xl border border-white/5">
                        <span class="text-xs font-bold text-gray-400 uppercase">@MovieLocalizer["YourRating"].Value</span>
                        <div class="flex gap-1" id="main-star-selector">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <span class="material-symbols-outlined text-2xl cursor-pointer text-gray-600 star-btn" data-val="@i">star</span>
                            }
                        </div>
                        <input type="hidden" name="MovieReview" id="ratingInput" value="0" />
                    </div>
                    <button type="submit" class="bg-blue-600 hover:bg-blue-500 text-white font-black px-10 py-4 rounded-xl transition-all shadow-lg flex items-center gap-2">
                        @MovieLocalizer["PublishButton"].Value <span class="material-symbols-outlined text-sm">send</span>
                    </button>
                </div>
            </div>
        </form>
    }
    else
    {
        <div class="glass-card p-8 rounded-2xl mb-12 text-center border-l-4 border-yellow-500">
            <p class="text-gray-300">@MovieLocalizer["LoginToComment"].Value</p>
        </div>
    }
    <div id="commentsListArea">
        <div class="text-center py-10"><span class="material-symbols-outlined animate-spin text-4xl text-blue-500">refresh</span></div>
    </div>
</div>