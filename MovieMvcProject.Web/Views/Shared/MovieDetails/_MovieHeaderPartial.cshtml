@using Microsoft.Extensions.Localization
@model MovieMvcProject.Web.Models.MovieDetailViewModel
@inject IStringLocalizer<MovieMvcProject.Domain.Resources.EnumResource> EnumLocalizer
@inject IStringLocalizer<MovieMvcProject.Domain.Resources.MovieResource> MovieLocalizer

@{
    var movie = Model.MovieDetail;
}

<div class="flex flex-col lg:flex-row gap-12">
    <div class="w-full lg:w-[350px] flex-shrink-0">
        <div class="relative group rounded-3xl overflow-hidden shadow-2xl border-4 border-[#1a2033]">
            <img src="@movie?.PosterUrl" class="w-full h-auto" alt="@MovieLocalizer["Title"].Value" />
            @if (!string.IsNullOrEmpty(movie?.VideoUrl))
            {
                <button onclick="openTrailer()" class="absolute inset-0 bg-black/40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-500">
                    <span class="material-symbols-outlined text-8xl text-white drop-shadow-lg">play_circle</span>
                </button>
            }
        </div>
    </div>
    <div class="flex-1 pt-14 space-y-8">
        <div>
            <div class="flex items-center gap-3 mb-4">
                <span class="bg-blue-600/20 text-blue-400 border border-blue-600/30 text-[11px] font-black uppercase px-3 py-1 rounded-lg">@EnumLocalizer.GetLocalizedCategory(movie.Category)</span>
                <span class="text-gray-400 text-sm font-bold">@movie?.Year</span>
                <span class="text-gray-600">•</span>
                <span class="text-gray-400 text-sm font-bold">@movie?.DurationInMinutes @MovieLocalizer["MinutesShort"].Value</span>
            </div>
            <h1 class="text-5xl md:text-7xl font-black italic uppercase leading-none tracking-tighter">@movie?.Title</h1>
        </div>
        
        <div class="flex flex-wrap md:flex-nowrap items-center justify-center md:justify-between gap-4 md:gap-0 bg-white/5 p-4 rounded-3xl border border-white/5 backdrop-blur-md w-full">
            <div class="flex items-center gap-3 px-4 flex-shrink-0 w-full sm:w-auto justify-center sm:justify-start">
                <span class="material-symbols-outlined text-yellow-500 text-3xl" style="font-variation-settings: 'FILL' 1">star</span>
                <div class="flex flex-col text-left">
                    <span class="text-[10px] text-gray-500 uppercase font-black">IMDb</span>
                    <span class="text-3xl font-black text-white leading-tight">@movie?.Rating.ToString("F1")</span>
                </div>
            </div>
            <div class="hidden md:block w-px h-10 bg-white/10"></div>
            <div class="flex items-center gap-4 px-4 flex-shrink-0 w-full sm:w-auto justify-center sm:justify-start">
                <div class="relative">
                    <img src="@movie?.DirectorPhotoUrl" class="w-11 h-11 rounded-full object-cover ring-2 ring-white/5" onerror="this.src='/profile-images/default-profile.png'" />
                </div>
                <div class="flex flex-col text-left">
                    <span class="text-[10px] text-gray-500 uppercase font-bold">@MovieLocalizer["Director"].Value</span>
                    <a asp-controller="Directors" asp-action="Details" asp-route-id="@movie?.DirectorId"
                       class="text-base font-bold text-white hover:text-blue-500 transition-colors leading-tight">@movie?.Director</a>
                </div>
            </div>
            <div class="hidden md:block w-px h-10 bg-white/10"></div>
            <div class="flex items-center gap-4 px-4 flex-shrink-0 w-full sm:w-auto justify-center sm:justify-start">
                <div class="w-11 h-11 flex items-center justify-center bg-yellow-500/10 rounded-full border border-yellow-500/20">
                    <span class="material-symbols-outlined text-yellow-500 text-2xl" style="font-variation-settings: 'FILL' 1">star</span>
                </div>
                <div class="flex flex-col text-left">
                    <span class="text-[10px] text-gray-500 uppercase font-bold">@MovieLocalizer["UserRating"].Value</span>
                    <div class="flex items-baseline gap-1">
                        <span class="text-lg font-black text-white">@(movie?.MovieAvgReviewRate > 0 ? movie.MovieAvgReviewRate.ToString("F1") : "—")</span>
                        <span class="text-[10px] text-gray-500 font-bold">/ 5</span>
                    </div>
                </div>
            </div>
            <div class="hidden md:block w-px h-10 bg-white/10"></div>
            <div class="px-2 flex-shrink-0 w-full md:w-auto mt-2 md:mt-0">
                <button id="btnWishlist" onclick="addToWishlist('@movie?.MovieId')" class="group w-full md:w-auto flex items-center justify-center gap-3 px-6 py-3 rounded-2xl bg-white/10 hover:bg-red-500/20 border border-white/10 transition-all">
                    <span id="wishlistIcon" class="material-symbols-outlined text-red-500 group-hover:scale-110 transition-transform">favorite</span>
                    <div class="text-left">
                        <span class="block text-[10px] text-gray-400 font-bold uppercase leading-none">@MovieLocalizer["AddToMyList"].Value</span>
                        <span class="block text-sm font-bold text-white">@MovieLocalizer["AddButton"].Value</span>
                    </div>
                </button>
            </div>
        </div>
        <p class="text-gray-400 text-lg leading-relaxed max-w-4xl font-light">@movie?.Description</p>
    </div>
</div>