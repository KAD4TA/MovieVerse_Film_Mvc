@using Microsoft.AspNetCore.Mvc.Localization
@using MovieMvcProject.Domain.Resources
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<MovieResource> MovieLocalizer

<header class="max-w-7xl mx-auto mb-16 md:mb-24 text-left px-4">
    <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black tracking-tighter mb-4 italic uppercase leading-[1.2]">
        <span class="inline-block pr-4">@MovieLocalizer["Genre"]</span>
        <br class="hidden sm:block" />
        <span class="relative inline-block text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-500 py-4 px-8 -ml-8 -my-4 overflow-visible">
            @MovieLocalizer["Explorer"]
        </span>
    </h1>
    <p class="text-gray-400 max-w-2xl text-base md:text-lg font-light leading-relaxed border-l-2 border-blue-600/30 pl-4 mt-6">
        @MovieLocalizer["FilterDesc"]
    </p>
</header>