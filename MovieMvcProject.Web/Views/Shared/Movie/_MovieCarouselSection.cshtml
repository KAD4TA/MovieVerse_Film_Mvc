
@model MovieMvcProject.Web.Models.MovieCarouselModel

@if (Model.Movies != null && Model.Movies.Any())
{
    <section class="mt-10 mb-8">
       
        <div class="flex items-center justify-between px-4 sm:px-10 mb-4">
            
            <h2 class="text-2xl font-bold text-white border-l-4 border-primary pl-3">
                @Model.MenuLocalizer[Model.HeaderKey]
            </h2>

            
            <div class="hidden md:flex gap-2">
                <button onclick="scrollSection('@Model.SectionId', -300)"
                        class="bg-gray-800 hover:bg-gray-700 text-white p-2 rounded-full transition-colors border border-gray-700">
                    <span class="material-symbols-outlined text-xl">chevron_left</span>
                </button>
                <button onclick="scrollSection('@Model.SectionId', 300)"
                        class="bg-gray-800 hover:bg-gray-700 text-white p-2 rounded-full transition-colors border border-gray-700">
                    <span class="material-symbols-outlined text-xl">chevron_right</span>
                </button>
            </div>
        </div>

        @* --- Liste Alanı --- *@
        <div class="relative group px-2 sm:px-8">

            
            <button class="absolute left-0 top-1/2 -translate-y-1/2 z-20 bg-black/60 p-2 rounded-r-lg text-white opacity-0 group-hover:opacity-100 transition-opacity hidden md:block hover:bg-primary"
                    onclick="scrollSection('@Model.SectionId', -300)">
                <span class="material-symbols-outlined">chevron_left</span>
            </button>

            
            <div id="@Model.SectionId"
                 class="flex overflow-x-auto gap-4 py-4 px-2 scroll-smooth hide-scrollbar">

                @foreach (var movie in Model.Movies)
                {
                    <partial name="_MovieCard" model="movie" />
                }
            </div>

           
            <button class="absolute right-0 top-1/2 -translate-y-1/2 z-20 bg-black/60 p-2 rounded-l-lg text-white opacity-0 group-hover:opacity-100 transition-opacity hidden md:block hover:bg-primary"
                    onclick="scrollSection('@Model.SectionId', 300)">
                <span class="material-symbols-outlined">chevron_right</span>
            </button>
        </div>
    </section>
}