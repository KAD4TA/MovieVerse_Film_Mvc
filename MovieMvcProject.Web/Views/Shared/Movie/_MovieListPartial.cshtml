@model MovieMvcProject.Application.Commons.PagedResult<MovieMvcProject.Application.DTOs.ResponseDto.MovieDtoResponse>
@using System.Text.Json
@using MovieMvcProject.Domain.Resources
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<EnumResource> EnumLocalizer
@inject IStringLocalizer<MenuResource> MenuLocalizer

@{
    var allMovies = Model?.Items ?? Array.Empty<MovieMvcProject.Application.DTOs.ResponseDto.MovieDtoResponse>();
    var heroMovies = allMovies.Where(m => m.IsOnSlider).Take(5).ToList();
    var featuredMovie = heroMovies.FirstOrDefault();
}


<script>
    window.movieSliderConfig = {
        yearLabel: '@MenuLocalizer["YearLabel"]',
        detailBaseUrl: '/Movie'
    };
</script>

<main class="flex-1 bg-gray-900 min-h-screen">
    @* --- 1. HERO SECTION --- *@
    <section class="max-w-7xl mx-auto px-0 sm:px-4 md:px-10 py-6">
        @if (featuredMovie != null)
        {
            <div id="featuredMovieContainer"
                 data-movies='@Html.Raw(JsonSerializer.Serialize(heroMovies, new JsonSerializerOptions { PropertyNamingPolicy = null }))'
                 class="featured-container relative min-h-[400px] md:min-h-[550px] flex flex-col items-start justify-end px-6 pb-12 overflow-hidden rounded-none md:rounded-3xl bg-cover bg-center shadow-2xl"
                 style='background-image: linear-gradient(to top, rgba(17,24,39,1) 0%, rgba(17,24,39,0.3) 50%, rgba(17,24,39,0.1) 100%), url("@featuredMovie.PosterUrl");'>

                <div class="z-10 max-w-2xl animate-fade-in">
                    <div id="featuredMovieContent">
                        <h1 class="text-white text-4xl md:text-6xl font-black mb-4 drop-shadow-lg">@featuredMovie.Title</h1>
                        <p class="text-gray-300 text-lg md:text-xl mb-6">
                            @MenuLocalizer["YearLabel"]: @(featuredMovie.Year > 0 ? featuredMovie.Year.ToString() : "2024") • ★ @featuredMovie.Rating
                        </p>
                    </div>
                    <div class="flex gap-4">
                        <a asp-controller="Movie" asp-action="MovieDetail" asp-route-id="@featuredMovie.MovieId"
                               id="watchNowLink"
                               class="bg-primary hover:bg-red-700 text-white px-8 py-3 rounded-full font-bold transition-all hover:scale-105 inline-block">
                            @MenuLocalizer["WatchNowButton"]
                        </a>
                    </div>
                </div>
            </div>
        }
    </section>

    @* --- 2. GRID LISTELEME --- *@
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <h2 class="text-2xl font-bold text-white uppercase tracking-wider border-l-4 border-primary pl-4 mb-8">
            @MenuLocalizer["AllMovies"]
        </h2>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">
            @foreach (var movie in allMovies)
            {
                <a asp-controller="Movie" asp-action="MovieDetail" asp-route-id="@movie.MovieId" class="group relative">
                    <div class="aspect-[2/3] overflow-hidden rounded-xl bg-gray-800 ring-1 ring-gray-700 transition-all duration-300 group-hover:ring-primary shadow-lg">
                        <img src="@movie.PosterUrl" alt="@movie.Title" class="movie-card-img h-full w-full object-cover" loading="lazy">
                        <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex flex-col justify-end p-4">
                            <span class="text-primary font-bold text-sm">★ @movie.Rating</span>
                            <span class="text-white text-xs">@EnumLocalizer.GetLocalizedCategory(movie.Category)</span>
                        </div>
                    </div>
                    <div class="mt-3">
                        <h3 class="text-sm font-semibold text-gray-200 truncate group-hover:text-primary transition-colors">@movie.Title</h3>
                        <p class="text-xs text-gray-500">@(movie.Year > 0 ? movie.Year : 2024)</p>
                    </div>
                </a>
            }
        </div>

        @* --- 3. PAGINATION --- *@
        @if (Model.TotalPages > 1)
        {
            <div class="flex justify-center items-center gap-2 mt-16 pb-10">
                @if (Model.HasPreviousPage)
                {
                    <a asp-action="Index" asp-route-pageNumber="@(Model.PageNumber - 1)"
                       class="px-4 py-2 bg-gray-800 text-white rounded-lg hover:bg-primary transition-all">&laquo;</a>
                }
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    if (i == 1 || i == Model.TotalPages || (i >= Model.PageNumber - 2 && i <= Model.PageNumber + 2))
                    {
                        <a asp-action="Index" asp-route-pageNumber="@i"
                               class="px-4 py-2 rounded-lg font-bold transition-all @(i == Model.PageNumber ? "bg-primary text-white scale-110 shadow-lg" : "bg-gray-800 text-gray-400 hover:bg-gray-700 hover:text-white")">
                            @i
                        </a>
                    }
                    else if (i == Model.PageNumber - 3 || i == Model.PageNumber + 3)
                    {
                        <span class="text-gray-600 px-1">...</span>
                    }
                }
                @if (Model.HasNextPage)
                {
                    <a asp-action="Index" asp-route-pageNumber="@(Model.PageNumber + 1)"
                       class="px-4 py-2 bg-gray-800 text-white rounded-lg hover:bg-primary transition-all">&raquo;</a>
                }
            </div>
        }
    </section>
</main>