@model List<MovieMvcProject.Application.DTOs.ResponseDto.MovieDtoResponse>
@using Microsoft.Extensions.Localization
@using MovieMvcProject.Domain.Resources
@using System.Text.Json
@inject IStringLocalizer<MenuResource> MenuLocalizer

@{
    var featuredMovie = Model?.FirstOrDefault();
}

<section class="max-w-7xl mx-auto px-0 sm:px-4 md:px-10 py-6">
    @if (featuredMovie != null)
    {
        <div id="featuredMovieContainer"
             data-movies='@Html.Raw(JsonSerializer.Serialize(Model, new JsonSerializerOptions { PropertyNamingPolicy = null }))'
             data-year-label='@MenuLocalizer["YearLabel"]'
             class="relative min-h-[400px] md:min-h-[550px] flex flex-col items-start justify-end px-6 pb-12 overflow-hidden rounded-none md:rounded-3xl transition-all duration-1000 ease-in-out bg-cover bg-center shadow-2xl"
             style='background-image: linear-gradient(to top, rgba(17,24,39,1) 0%, rgba(17,24,39,0.3) 50%, rgba(17,24,39,0.1) 100%), url("@featuredMovie.PosterUrl");'>

            <div class="z-10 max-w-2xl animate-fade-in">
                <div id="featuredMovieContent">
                    <h1 class="text-white text-4xl md:text-6xl font-black mb-4 drop-shadow-lg">
                        @featuredMovie.Title
                    </h1>
                    <p class="text-gray-300 text-lg md:text-xl mb-6">
                        @MenuLocalizer["YearLabel"]: @(featuredMovie.Year > 0 ? featuredMovie.Year.ToString() : "2024") • ★ @featuredMovie.Rating
                    </p>
                </div>

                <div class="flex gap-4">
                    <a asp-controller="Movie" asp-action="MovieDetail" asp-route-id="@featuredMovie.MovieId"
                           id="watchNowLink"
                           class="bg-primary hover:bg-red-700 text-white px-8 py-3 rounded-full font-bold transition-all hover:scale-105 inline-block">
                        @MenuLocalizer["WatchNowButton"]
                    </a>
                </div>
            </div>
        </div>
    }
</section>