@model MovieMvcProject.Web.Models.LoginViewModel
@inject MovieMvcProject.Application.Interfaces.ILocalization.ILocalizationService Loc

<div class="w-full max-w-md rounded-2xl login-glass-card p-8 shadow-2xl border border-white/10">
    <h1 class="mb-8 text-center text-4xl font-black tracking-tight">
        @Loc.GetLocalizedHtmlString("RegisterResource", "LoginLink")
    </h1>

    <form asp-controller="Account" asp-action="Login" method="post" class="space-y-6">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="text-red-400 text-sm"></div>

        <div>
            <label class="block text-sm font-medium text-background-light mb-2">
                @Loc.GetLocalizedHtmlString("RegisterResource", "EmailLabel")
            </label>
            <input asp-for="Email" type="email"
                   class="w-full px-4 py-3 rounded-lg bg-gray-900/70 border border-gray-700 text-white placeholder-gray-500 focus:border-primary focus:outline-none transition" />
            <span asp-validation-for="Email" class="text-red-400 text-xs mt-1"></span>
        </div>

        <div>
            <label class="block text-sm font-medium text-background-light mb-2">
                @Loc.GetLocalizedHtmlString("RegisterResource", "PasswordLabel")
            </label>
            <input asp-for="Password" type="password"
                   class="w-full px-4 py-3 rounded-lg bg-gray-900/70 border border-gray-700 text-white placeholder-gray-500 focus:border-primary focus:outline-none transition" />
            <span asp-validation-for="Password" class="text-red-400 text-xs mt-1"></span>
        </div>

        <div class="flex items-center gap-2">
            <input asp-for="RememberMe" type="checkbox"
                   class="w-5 h-5 accent-primary bg-gray-900 border-gray-600 rounded focus:ring-primary" />
            <label asp-for="RememberMe" class="text-sm font-medium text-gray-300 cursor-pointer select-none">
                @Loc.GetLocalizedHtmlString("RegisterResource", "RememberMe")
            </label>
        </div>

        <button type="submit" class="w-full py-4 bg-primary hover:bg-primary/90 text-white font-bold text-lg rounded-lg transition shadow-lg">
            @Loc.GetLocalizedHtmlString("RegisterResource", "LoginLink")
        </button>
    </form>

    <p class="text-center mt-6 text-gray-400">
        @Loc.GetLocalizedHtmlString("RegisterResource", "NoAccount")
        <a asp-controller="Account" asp-action="Register" class="text-primary hover:underline font-medium">
            @Loc.GetLocalizedHtmlString("RegisterResource", "RegisterButton")
        </a>
    </p>
</div>