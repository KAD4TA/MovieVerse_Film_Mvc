@model MovieMvcProject.Web.Models.SettingsPageViewModel
@using MovieMvcProject.Domain.Enums
@using Microsoft.Extensions.Localization
@using MovieMvcProject.Domain.Resources
@using MovieMvcProject.Web.Helpers

@inject IStringLocalizer<UserResource> Localizer
@inject MovieMvcProject.Application.Interfaces.ILocalization.ILocalizationService Loc

<section id="tab-profile" class="tab-content">
    <div class="mb-8 p-6 bg-white/5 border border-white/10 rounded-2xl profile-image-section">
        <label class="block text-sm font-semibold text-white mb-4">@Localizer["ProfilePictureLabel"]</label>
        <div class="flex items-center gap-6">
            <div class="relative">
                <div class="w-28 h-28 rounded-full overflow-hidden ring-4 ring-red-600/30">
                    <img id="profileImagePreview"
                         src="@(string.IsNullOrEmpty(Model?.ProfileImage) ? Url.Content("~/profile-images/default-profile.png") : Url.Content(Model.ProfileImage))"
                         class="w-full h-full object-cover" alt="Profil Resmi" />
                </div>
                <label for="ProfileImageFile"
                       class="absolute bottom-0 right-0 bg-red-600 hover:bg-red-500 text-white p-2 rounded-full cursor-pointer shadow-md transition">
                    <span class="material-symbols-outlined text-sm">photo_camera</span>
                </label>
                <input asp-for="ProfileImageFile"
                       id="ProfileImageFile"
                       type="file"
                       accept="image/png, image/jpeg, image/webp"
                       class="hidden"
                       onchange="handleProfileImageChange(this)" />
            </div>
            <div class="text-sm text-gray-400">
                <p>@Localizer["AllowedImageFormats"]</p>
                <p>@Localizer["MaxFileSize"]</p>
            </div>
        </div>
        <span asp-validation-for="ProfileImageFile" class="text-sm text-red-500 mt-3 block"></span>
        <p id="imageError" class="text-sm text-red-500 mt-3 hidden"></p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 form-grid-section">
        <div>
            <label class="text-sm font-semibold text-gray-400">@Localizer["FullNameLabel"]</label>
            <input asp-for="FullName"
                   class="w-full bg-gray-800/50 border border-white/10 rounded-xl px-4 py-3 text-white focus:ring-2 focus:ring-red-600/50 outline-none" />
            <span asp-validation-for="FullName" class="text-sm text-red-500 mt-1 block"></span>
        </div>
        <div class="opacity-70">
            <label class="text-sm font-semibold text-gray-400">@Localizer["EmailLabel"]</label>
            <input asp-for="Email" readonly
                   class="w-full bg-black/30 border border-white/5 rounded-xl px-4 py-3 text-gray-500 cursor-not-allowed" />
        </div>
        <div>
            <label class="text-sm font-semibold text-gray-400 block mb-2">@Loc.GetLocalizedHtmlString("RegisterResource", "GenderLabel")</label>
            <select asp-for="Gender"
                    asp-items="@EnumSelectListHelper.GetLocalizedEnumSelectList<Gender>(Loc)"
                    class="w-full bg-gray-800/50 border border-white/10 rounded-xl px-4 py-3 text-white focus:ring-2 focus:ring-red-600/50 outline-none appearance-none">
                <option value="">@Loc.GetLocalizedHtmlString("RegisterResource", "SelectGender")</option>
            </select>
        </div>
        <div>
            <label class="text-sm font-semibold text-gray-400">@Localizer["BirthDateLabel"]</label>
            <input asp-for="BirthDate" type="date"
                   class="w-full bg-gray-800/50 border border-white/10 rounded-xl px-4 py-3 text-white" />
        </div>

        <div>

            <label class="text-sm font-semibold text-gray-400">@Localizer["InstagramLabel"]</label>

            <div class="relative mt-1">

                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">

                    <svg class="w-5 h-5 text-gray-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">

                        <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />

                    </svg>

                </div>

                <input asp-for="InstagramUrl" placeholder="@Localizer["InstagramPlaceholder"]"
                       class="w-full bg-gray-800/50 border border-white/10 rounded-xl pl-10 pr-4 py-3 text-white focus:ring-2 focus:ring-red-600/50 outline-none transition" />

            </div>

            <span asp-validation-for="InstagramUrl" class="text-sm text-red-500 mt-1 block"></span>
        </div><div>

        <label class="text-sm font-semibold text-gray-400">@Localizer["TwitterLabel"]</label>

        <div class="relative mt-1">

            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">

                <svg class="w-5 h-5 text-gray-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">

                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />

                </svg>

            </div>

            <input asp-for="TwitterUrl" placeholder="@Localizer["TwitterPlaceholder"]"
                   class="w-full bg-gray-800/50 border border-white/10 rounded-xl pl-10 pr-4 py-3 text-white focus:ring-2 focus:ring-red-600/50 outline-none transition" />

        </div>

        <span asp-validation-for="TwitterUrl" class="text-sm text-red-500 mt-1 block"></span>
    </div>
    </div>


  
    <div class="mt-10 p-6 bg-red-900/10 border border-red-500/30 rounded-2xl">
        <h3 class="text-lg font-semibold text-red-500 mb-2">@Localizer["DangerZoneTitle"]</h3>
        <p class="text-sm text-gray-400 mb-4">@Localizer["DeleteAccountWarning"]</p>
    
        <button type="button"
                onclick="showDeleteModal()"
                class="bg-red-600 hover:bg-red-700 text-white font-bold px-6 py-2 rounded-xl transition shadow-lg shadow-red-600/20">
            @Localizer["DeleteAccountButton"]
        </button>
    </div>
</section>