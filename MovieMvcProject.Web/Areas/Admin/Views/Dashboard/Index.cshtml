@model MovieMvcProject.Web.Areas.Admin.Models.DashboardViewModel
@using MovieMvcProject.Application.DTOs.Dashboard
@using MovieMvcProject.Web.Areas.Admin.Resources
@using Microsoft.Extensions.Localization
@using Microsoft.AspNetCore.Identity
@using MovieMvcProject.Domain.Identity
@using System.Globalization

@inject IStringLocalizer<AdminResource> AdminLocalizer
@inject UserManager<AppUser> UserManager

@{
    ViewData["Title"] = AdminLocalizer["Dashboard.Title"];
    Layout = "_LayoutAdmin";
    var currentUser = await UserManager.GetUserAsync(User);
    string userName = currentUser?.FullName ?? "Yönetici";
}

<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script src="~/js/dashboard/dashboard.js" asp-append-version="true"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
<link href="https://fonts.googleapis.com/icon?family=Material+Symbols+Outlined" rel="stylesheet">
<link rel="stylesheet" href="~/css/dashboard/dashboard.css" asp-append-version="true" />

<div class="bg-slate-50 dark:bg-[#0f172a] text-slate-900 dark:text-slate-300 transition-colors duration-300 p-4 md:p-8 min-h-screen">
    <main class="max-w-[1600px] mx-auto space-y-8">
        
        <div class="flex flex-col md:flex-row justify-between items-end md:items-center gap-4 pb-4">
            <div>
                <p class="text-slate-500 dark:text-slate-400 text-sm font-medium mb-1">@AdminLocalizer["Dashboard.WelcomeBack"]</p>
                <h1 class="text-3xl md:text-4xl font-bold text-slate-800 dark:text-white flex items-center gap-2">@userName <span class="animate-bounce">👋</span></h1>
            </div>
            <div class="flex items-center gap-3 bg-white dark:bg-[#1e293b] px-5 py-3 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm glow-cyan">
                <div class="p-2 bg-neon-cyan/10 rounded-lg text-neon-cyan"><span class="material-symbols-outlined">schedule</span></div>
                <div class="text-right">
                    <div id="clock-time" class="text-xl font-bold dark:text-white leading-none font-mono tracking-wide">--:--</div>
                    <div id="clock-date" class="text-xs text-slate-500 dark:text-slate-400 font-medium uppercase tracking-wider mt-1">---</div>
                </div>
            </div>
        </div>

        @await Html.PartialAsync("Dashboard/_DashboardStatsCardsPartial", Model)

        <section class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            @await Html.PartialAsync("Dashboard/_DashboardMainChartPartial", Model)
            @await Html.PartialAsync("Dashboard/_DashboardGenrePartial", Model)
        </section>

        @await Html.PartialAsync("Dashboard/_DashboardRecentLogsPartial", Model)
    </main>

    @await Html.PartialAsync("Dashboard/_DashboardReportModalPartial", Model)

    
</div>

@section Scripts {
    @await Html.PartialAsync("Dashboard/_DashboardScriptsPartial", Model)
}