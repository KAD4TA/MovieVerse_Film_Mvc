@model MovieMvcProject.Application.Commons.PagedResult<MovieMvcProject.Web.Areas.Admin.Models.MovieViewModel>
@using MovieMvcProject.Application.Commons
@using Microsoft.AspNetCore.Mvc.Localization
@using MovieMvcProject.Domain.Resources
@using Microsoft.Extensions.Localization
@using MovieMvcProject.Web.Areas.Admin.Resources
@inject IStringLocalizer<AdminMovieResource> AdminMovieLocalizer
@inject IStringLocalizer<EnumResource> EnumLocalizer
@{
    ViewData["Title"] = AdminMovieLocalizer["AdminMovieList"];
    Layout = "_LayoutAdmin";
    var totalItems = Model?.TotalCount ?? 0;
    var pageSize = Model?.PageSize ?? 10;
    var currentPage = Model?.PageNumber ?? 1;
    var totalPages = Model?.TotalPages ?? 1;
    var hasPreviousPage = Model?.HasPreviousPage ?? false;
    var hasNextPage = Model?.HasNextPage ?? false;
    var searchTerm = ViewBag.SearchTerm as string ?? "";
    int spread = 2;
    int startPage = Math.Max(1, currentPage - spread);
    int endPage = Math.Min(totalPages, currentPage + spread);
}

<link rel="stylesheet" href="~/css/admin/admin-movie-list.css" asp-append-version="true" />

<div class="p-8 flex flex-col gap-8 w-full max-w-[1920px] mx-auto transition-colors duration-300">

    @* --- BİLDİRİM PANELLERİ --- *@
    @if (TempData["Success"] != null)
    {
        <div class="flex items-center p-4 rounded-2xl bg-green-500/10 border border-green-500/20 shadow-[0_0_15px_rgba(16,185,129,0.1)] animate-fade-in text-green-600 dark:text-green-400" role="alert">
            <span class="material-icons-outlined mr-3 text-xl">check_circle</span>
            <div class="text-sm font-bold">@TempData["Success"]</div>
        </div>
    }

    @* --- ÜST BAR: BAŞLIK VE ARAMA --- *@
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
        <div>
            <h1 class="text-3xl font-black text-gray-900 dark:text-white tracking-tight flex items-center gap-3">
                <span class="w-2 h-8 bg-primary rounded-full shadow-[0_0_10px_rgba(139,92,246,0.5)]"></span>
                @AdminMovieLocalizer["AllMovies"]
            </h1>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-2 font-medium pl-5">
                @AdminMovieLocalizer["TotalFound"]: <span class="text-gray-900 dark:text-white">@totalItems</span> @AdminMovieLocalizer["MoviesListed"]
            </p>
        </div>
        <div class="flex flex-col sm:flex-row items-center gap-4 w-full md:w-auto">
            @* Arama Formu *@
            <form asp-area="Admin" asp-controller="Admin" asp-action="MovieList" method="get" class="w-full sm:w-auto flex-1">
                <div class="relative group">
                    <input type="search" name="searchTerm" value="@searchTerm" placeholder="@AdminMovieLocalizer["SearchPlaceholder"]..."
                           class="w-full sm:w-72 pl-11 pr-4 py-2.5 rounded-xl bg-white dark:bg-surface-dark border border-gray-200 dark:border-white/10 text-gray-900 dark:text-gray-200 placeholder-gray-500 focus:ring-2 focus:ring-primary/50 focus:border-primary/50 outline-none text-sm transition-all group-hover:bg-gray-50 dark:group-hover:bg-white/5 shadow-sm" />
                    <span class="material-icons-outlined absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400 group-focus-within:text-primary transition-colors">search</span>
                </div>
            </form>

            @* Yeni Ekle Butonu *@
            <a asp-area="Admin" asp-controller="Admin" asp-action="CreateMovie"
                   class="w-full sm:w-auto px-6 py-2.5 rounded-xl bg-primary text-white font-bold text-sm shadow-[0_0_15px_rgba(139,92,246,0.4)] hover:shadow-[0_0_25px_rgba(139,92,246,0.6)] hover:scale-105 active:scale-95 transition-all flex items-center justify-center gap-2 border border-primary/50">
                <span class="material-icons-outlined text-lg">add_circle</span>
                @AdminMovieLocalizer["AddNew"]
            </a>
        </div>
    </div>

    @* --- TABLO KARTI --- *@
    <div class="bg-white dark:bg-surface-dark rounded-3xl border border-gray-200 dark:border-white/5 shadow-xl dark:shadow-2xl overflow-hidden backdrop-blur-sm transition-colors">
        <div class="overflow-x-auto">
            <table class="min-w-full text-left">
                <thead>
                    <tr class="border-b border-gray-100 dark:border-white/5 bg-gray-50 dark:bg-black/20">
                        <th class="px-6 py-5 text-xs font-black text-gray-400 dark:text-gray-500 uppercase tracking-wider">@AdminMovieLocalizer["PosterLabel"]</th>
                        <th class="px-6 py-5 text-xs font-black text-gray-400 dark:text-gray-500 uppercase tracking-wider">@AdminMovieLocalizer["TitleLabel"]</th>
                        <th class="px-6 py-5 text-xs font-black text-gray-400 dark:text-gray-500 uppercase tracking-wider text-center">@AdminMovieLocalizer["YearLabel"]</th>
                        <th class="px-6 py-5 text-xs font-black text-gray-400 dark:text-gray-500 uppercase tracking-wider text-center">@AdminMovieLocalizer["RatingLabel"]</th>
                        <th class="px-6 py-5 text-xs font-black text-gray-400 dark:text-gray-500 uppercase tracking-wider">@AdminMovieLocalizer["CategoryLabel"]</th>
                        
                        <th class="px-6 py-5 text-xs font-black text-gray-400 dark:text-gray-500 uppercase tracking-wider text-center">Slider</th>
                        
                        <th class="px-6 py-5 text-xs font-black text-gray-400 dark:text-gray-500 uppercase tracking-wider text-right">@AdminMovieLocalizer["ActionsLabel"]</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 dark:divide-white/5 text-gray-700 dark:text-gray-300">
                    @if (Model?.Items != null && Model.Items.Any())
                    {
                        @foreach (var movie in Model.Items)
                        {
                            var localizedCategory = EnumLocalizer["Category_" + movie.Category];
                            <tr class="group hover:bg-gray-50 dark:hover:bg-white/5 transition-colors duration-200">
                                @* Poster *@
                                <td class="px-6 py-4 w-20">
                                    <div class="relative w-12 h-16 rounded-lg overflow-hidden shadow-lg border border-gray-200 dark:border-white/10 group-hover:ring-2 ring-primary/50 transition-all">
                                        <img class="w-full h-full object-cover transform group-hover:scale-110 transition duration-500"
                                             src="@movie.PosterUrl"
                                             alt="@movie.Title"
                                             onerror="this.onerror=null;this.src='/images/no-poster.jpg';"
                                             loading="lazy">
                                    </div>
                                </td>
                                @* Başlık & ID *@
                                <td class="px-6 py-4">
                                    <div class="font-bold text-gray-900 dark:text-gray-200 group-hover:text-primary transition-colors text-sm">@movie.Title</div>
                                    <div class="text-[10px] text-gray-400 dark:text-gray-600 font-mono mt-0.5">ID: <span class="text-gray-500">#@movie.MovieId</span></div>
                                </td>
                                @* Yıl *@
                                <td class="px-6 py-4 text-center">
                                    <span class="text-sm font-medium text-gray-600 dark:text-gray-400 bg-gray-100 dark:bg-white/5 px-2 py-1 rounded">
                                        @(movie.Year > 0 ? movie.Year.ToString() : AdminMovieLocalizer["NA"])
                                    </span>
                                </td>
                                @* Puan *@
                                <td class="px-6 py-4 text-center">
                                    @{
                                        var ratingColor = movie.Rating >= 7.5 ? "text-green-600 dark:text-green-400 border-green-500/30 bg-green-500/10 shadow-[0_0_10px_rgba(74,222,128,0.1)]" :
                                        movie.Rating >= 5.0 ? "text-yellow-600 dark:text-yellow-400 border-yellow-500/30 bg-yellow-500/10" :
                                        "text-red-600 dark:text-red-400 border-red-500/30 bg-red-500/10";
                                    }
                                    <div class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg border font-bold text-xs @ratingColor">
                                        <span class="material-icons-outlined text-[10px]">star</span>
                                        @movie.Rating.ToString("F1")
                                    </div>
                                </td>
                                @* Kategori *@
                                <td class="px-6 py-4">
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full bg-gray-100 dark:bg-white/5 text-gray-600 dark:text-gray-300 text-[11px] font-bold border border-gray-200 dark:border-white/10 uppercase tracking-wide group-hover:border-primary/30 transition-colors">
                                        <span class="w-1.5 h-1.5 rounded-full bg-primary mr-2 animate-pulse"></span>
                                        @localizedCategory
                                    </span>
                                </td>

                                <td class="px-6 py-4 text-center">
                                    <label class="relative inline-flex items-center cursor-pointer">
                                        <input type="checkbox" class="sr-only peer slider-toggle"
                                               data-id="@movie.MovieId"
                                        @(movie.IsOnSlider ? "checked" : "")>
                                        <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-primary"></div>
                                    </label>
                                </td>

                                @* İşlemler *@
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-2 opacity-60 group-hover:opacity-100 transition-opacity">
                                        <a asp-action="EditMovie" asp-route-id="@movie.MovieId"
                                               class="w-8 h-8 flex items-center justify-center rounded-lg bg-gray-100 dark:bg-white/5 text-blue-600 dark:text-blue-400 hover:bg-blue-600 hover:text-white border border-gray-200 dark:border-white/5 transition-all"
                                               title="@AdminMovieLocalizer["Edit"]">
                                            <span class="material-icons-outlined text-base">edit</span>
                                        </a>
                                        <button type="button"
                                                onclick="openDeleteModal('@movie.MovieId', '@movie.Title', '@movie.PosterUrl', '@movie.Year', '@localizedCategory', '@movie.Rating.ToString("F1")')"
                                                class="w-8 h-8 flex items-center justify-center rounded-lg bg-gray-100 dark:bg-white/5 text-red-600 dark:text-red-400 hover:bg-red-600 hover:text-white border border-gray-200 dark:border-white/5 transition-all"
                                                title="@AdminMovieLocalizer["Delete"]">
                                            <span class="material-icons-outlined text-base">delete</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="px-6 py-24 text-center">
                                <div class="flex flex-col items-center justify-center">
                                    <div class="w-20 h-20 bg-gray-100 dark:bg-white/5 rounded-full flex items-center justify-center mb-4">
                                        <span class="material-icons-outlined text-4xl text-gray-400">movie_filter</span>
                                    </div>
                                    <p class="text-lg font-bold text-gray-500 dark:text-gray-400">@AdminMovieLocalizer["NoDataFound"]</p>
                                    <p class="text-sm text-gray-400 mt-1">@AdminMovieLocalizer["NoDataMessage"]</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* --- SAYFALAMA --- *@
        <div class="px-6 py-5 border-t border-gray-100 dark:border-white/5 bg-gray-50 dark:bg-black/20 flex flex-col sm:flex-row items-center justify-between gap-4">
            <span class="text-xs text-gray-500 font-medium">
                @AdminMovieLocalizer["Page"] <span class="text-gray-900 dark:text-white">@currentPage</span> / @totalPages
            </span>
            <nav class="flex items-center gap-2">
                <a asp-action="MovieList" asp-route-pageNumber="@(currentPage - 1)" asp-route-searchTerm="@searchTerm"
                       class="w-9 h-9 flex items-center justify-center rounded-lg bg-white dark:bg-surface-dark border border-gray-200 dark:border-white/10 text-gray-400 hover:border-primary/50 hover:text-white transition-all shadow-sm @(!hasPreviousPage ? "opacity-30 pointer-events-none" : "")">
                    <span class="material-icons-outlined text-lg">chevron_left</span>
                </a>
                @for (int i = startPage; i <= endPage; i++)
                {
                    <a asp-action="MovieList" asp-route-pageNumber="@i" asp-route-searchTerm="@searchTerm"
                           class="w-9 h-9 flex items-center justify-center rounded-lg text-sm font-bold border transition-all @(i == currentPage ? "bg-primary border-primary text-white shadow-[0_0_10px_rgba(139,92,246,0.3)]" : "bg-white dark:bg-surface-dark border-gray-200 dark:border-white/10 text-gray-400 hover:bg-gray-50 dark:hover:bg-white/5 hover:text-white")">
                        @i
                    </a>
                }
                <a asp-action="MovieList" asp-route-pageNumber="@(currentPage + 1)" asp-route-searchTerm="@searchTerm"
                       class="w-9 h-9 flex items-center justify-center rounded-lg bg-white dark:bg-surface-dark border border-gray-200 dark:border-white/10 text-gray-400 hover:border-primary/50 hover:text-white transition-all shadow-sm @(!hasNextPage ? "opacity-30 pointer-events-none" : "")">
                    <span class="material-icons-outlined text-lg">chevron_right</span>
                </a>
            </nav>
        </div>
    </div>
</div>

@await Html.PartialAsync("DeleteMovie/_DeleteMovieModal")

@section Scripts {
    <script src="~/js/admin/admin-movie-list.js" asp-append-version="true"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const toggleButtons = document.querySelectorAll('.slider-toggle');

            toggleButtons.forEach(button => {
                button.addEventListener('change', function () {
                    const movieId = this.getAttribute('data-id');
                    const isOnSlider = this.checked;

                    // Controller'a AJAX isteği atıyoruz
                    fetch('/Admin/Admin/ToggleSlider', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            
                        },
                        body: JSON.stringify({
                            movieId: movieId,
                            isOnSlider: isOnSlider
                        })
                    })
                    .then(response => {
                        if (!response.ok) {
                            
                            this.checked = !isOnSlider;
                            alert("Durum güncellenirken bir hata oluştu.");
                        } else {
                            
                            console.log("Slider durumu güncellendi:", movieId, isOnSlider);
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        this.checked = !isOnSlider;
                        alert("Ağ hatası oluştu.");
                    });
                });
            });
        });
    </script>
}