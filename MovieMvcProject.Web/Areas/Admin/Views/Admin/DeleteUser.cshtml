@model MovieMvcProject.Web.Areas.Admin.Models.UserViewModel
@using Microsoft.Extensions.Localization
@using MovieMvcProject.Web.Areas.Admin.Resources

@inject IStringLocalizer<AdminResource> Localizer

@{
    var photoUrl = string.IsNullOrEmpty(Model.UserPhoto)
        ? "/profile-images/default-profile.png"
        : Model.UserPhoto;
}

<link rel="stylesheet" href="~/css/admin/user-delete.css" asp-append-version="true" />

<div class="min-h-[calc(100vh-64px)] flex items-center justify-center p-6 bg-slate-50 dark:bg-[#0f172a] transition-colors duration-300">
    <div class="max-w-2xl w-full">
        <div class="bg-white dark:bg-[#1e293b] border border-slate-200 dark:border-white/5 rounded-3xl shadow-xl dark:shadow-2xl overflow-hidden relative transition-all delete-card">
            <div class="bg-red-50 dark:bg-red-500/10 border-b border-red-100 dark:border-red-500/20 px-8 py-6 flex items-center gap-4">
                <div class="h-12 w-12 rounded-2xl bg-red-100 dark:bg-red-500/20 flex items-center justify-center">
                    <span class="material-icons-outlined text-red-600 dark:text-red-500 text-3xl">report_problem</span>
                </div>
                <div>
                    <h2 class="text-xl font-bold text-slate-800 dark:text-white tracking-tight">@Localizer["User.Delete.Confirmation"]</h2>
                    <p class="text-red-600 dark:text-red-400/80 text-xs font-black uppercase tracking-widest">@Localizer["Text.CriticalOperation"]</p>
                </div>
            </div>

            <div class="p-8 md:p-12 text-center">
                <div class="relative inline-block mb-6">
                    <div class="h-32 w-32 rounded-full ring-4 ring-red-500/20 p-1 bg-slate-100 dark:bg-[#0f172a]">
                        <img src="@photoUrl" alt="@Model.FullName" class="h-full w-full rounded-full object-cover shadow-2xl" />
                    </div>
                    <div class="absolute -bottom-2 -right-2 bg-red-600 text-white p-2 rounded-xl shadow-lg border-4 border-white dark:border-[#1e293b]">
                        <span class="material-icons-outlined text-xl">delete_forever</span>
                    </div>
                </div>

                <div class="space-y-2 mb-8">
                    <h3 class="text-2xl font-bold text-slate-800 dark:text-white">@Model.FullName</h3>
                    <p class="text-slate-500 dark:text-gray-400 font-medium">@Model.Email</p>
                    @if (!string.IsNullOrEmpty(Model.RoleNames))
                    {
                        <div class="pt-2 flex flex-wrap justify-center gap-2">
                            @foreach (var role in Model.RoleNames.Split(','))
                            {
                                <span class="px-3 py-1 bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-full text-[10px] font-bold text-slate-500 dark:text-gray-400 uppercase tracking-tighter">
                                    @role.Trim()
                                </span>
                            }
                        </div>
                    }
                </div>

                <div class="bg-slate-50 dark:bg-black/20 border border-slate-200 dark:border-white/5 rounded-2xl p-6 mb-10 text-left">
                    <p class="text-slate-600 dark:text-gray-300 text-sm leading-relaxed">
                        <span class="text-red-600 dark:text-red-400 font-bold">@Localizer["Text.Warning"]</span> @Localizer["User.Delete.WarningMessage"]
                    </p>
                </div>

                <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
                    <form asp-action="DeleteUser" method="post" class="w-full sm:w-auto">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.UserId" />
                        <button type="submit" class="w-full inline-flex items-center justify-center gap-2 px-8 py-4 bg-red-600 hover:bg-red-700 text-white font-bold rounded-2xl transition-all hover:scale-105 active:scale-95 shadow-lg shadow-red-600/20">
                            <span class="material-icons-outlined">check_circle</span>
                            @Localizer["Button.YesDeleteUser"]
                        </button>
                    </form>
                    <a asp-action="UserList" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 bg-slate-100 dark:bg-white/5 hover:bg-slate-200 dark:hover:bg-white/10 text-slate-600 dark:text-gray-300 hover:text-slate-900 dark:hover:text-white font-bold rounded-2xl border border-slate-200 dark:border-white/10 transition-all">
                        <span class="material-icons-outlined">close</span>
                        @Localizer["Button.Cancel"]
                    </a>
                </div>
            </div>

            <div class="absolute -top-24 -right-24 w-48 h-48 bg-red-600/10 blur-[100px] rounded-full pointer-events-none"></div>
            <div class="absolute -bottom-24 -left-24 w-48 h-48 bg-indigo-500/10 blur-[100px] rounded-full pointer-events-none"></div>
        </div>
    </div>
</div>