@using MovieMvcProject.Application.Interfaces.ILocalization
@using MovieMvcProject.Domain.Enums
@using MovieMvcProject.Domain.Enums.Extensions
@using Microsoft.Extensions.Localization
@using MovieMvcProject.Web.Areas.Admin.Resources
@inject ILocalizationService L
@inject IStringLocalizer<AdminRoleResource> Localizer
@model MovieMvcProject.Web.Areas.Admin.Models.ManageRolesViewModel

@{
    var photoUrl = string.IsNullOrEmpty(Model.UserPhoto)
        ? "/profile-images/default-profile.png"
        : Model.UserPhoto;
}

<div class="min-h-screen bg-slate-50 dark:bg-[#0f172a] transition-colors duration-300">
    <div class="container mx-auto px-6 py-8">
        @* --- ÜST BAŞLIK --- *@
        <div class="flex flex-col md:flex-row justify-between items-center mb-10 gap-4">
            <div class="flex items-center gap-4">
                <div class="w-14 h-14 bg-orange-600/10 dark:bg-orange-600/20 rounded-2xl flex items-center justify-center border border-orange-500/30 shadow-lg dark:shadow-glow-orange">
                    <span class="material-icons-outlined text-orange-500 text-3xl">manage_accounts</span>
                </div>
                <div>
                    <h1 class="text-3xl font-black text-slate-800 dark:text-white tracking-tight">@Localizer["ManageRolesHeader"]</h1>
                    <p class="text-slate-500 dark:text-gray-500 text-sm">@Localizer["Subtitle"]</p>
                </div>
            </div>
            <a asp-action="UserList" asp-controller="Admin" asp-area="Admin"
                   class="bg-white dark:bg-white/5 hover:bg-slate-100 dark:hover:bg-white/10 text-slate-600 dark:text-gray-300 border border-slate-200 dark:border-white/10 py-2.5 px-6 rounded-xl flex items-center gap-2 transition-all duration-300 group shadow-sm">
                <span class="material-icons-outlined text-lg group-hover:-translate-x-1 transition-transform">arrow_back</span>
                @Localizer["BackToList"]
            </a>
        </div>

        @* --- KULLANICI ÖZET KARTI --- *@
        <div class="bg-white dark:bg-[#1e293b] border border-slate-200 dark:border-white/5 rounded-3xl shadow-sm dark:shadow-2xl overflow-hidden mb-8 relative transition-all">
            <div class="absolute top-0 right-0 p-8 opacity-[0.03] dark:opacity-5">
                <span class="material-icons-outlined text-9xl text-slate-900 dark:text-white">shield</span>
            </div>
            <div class="p-8 relative z-10">
                <div class="flex flex-col md:flex-row items-start md:items-center gap-8">
                    <div class="relative group">
                        <div class="absolute -inset-1 bg-gradient-to-r from-orange-600 to-amber-600 rounded-full blur opacity-20 dark:opacity-30 group-hover:opacity-60 transition duration-500"></div>
                        <img src="@photoUrl" alt="@Model.UserName" class="relative h-32 w-32 rounded-full object-cover ring-4 ring-white dark:ring-[#1e293b] shadow-2xl" onerror="this.src='/profile-images/default-profile.png';" />
                    </div>
                    <div class="flex-1">
                        <div class="flex flex-wrap items-center gap-3">
                            <h2 class="text-4xl font-black text-slate-800 dark:text-white">@Model.UserName</h2>
                            <div class="flex items-center gap-2 px-3 py-1 bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-lg text-xs font-mono text-slate-500 dark:text-gray-400 break-all">
                                <span class="material-icons-outlined text-sm text-orange-500">fingerprint</span>
                                @Model.UserId
                            </div>
                        </div>
                        <div class="mt-4 flex flex-wrap gap-2">
                            @if (Model.UserRoles.Any())
                            {
                                foreach (var role in Model.UserRoles)
                                {
                                    <span class="px-3 py-1 rounded-lg bg-orange-500/10 text-orange-600 dark:text-orange-500 text-[10px] font-black uppercase tracking-wider border border-orange-500/20 flex items-center gap-1.5">
                                        <span class="w-1.5 h-1.5 rounded-full bg-orange-500 animate-pulse"></span>
                                        @role
                                    </span>
                                }
                            }
                            else
                            {
                                <span class="text-slate-400 dark:text-gray-500 text-sm italic font-medium">@Localizer["NoRolesAssigned"]</span>
                            }
                        </div>
                    </div>
                </div>

                @* Kullanıcı Meta Verileri *@
                <div class="mt-10 pt-8 border-t border-slate-100 dark:border-white/5 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                    <div class="flex items-center gap-4">
                        <div class="w-10 h-10 bg-slate-50 dark:bg-white/5 rounded-xl flex items-center justify-center text-orange-500">
                            <span class="material-icons-outlined text-xl">alternate_email</span>
                        </div>
                        <div>
                            <p class="text-[10px] text-slate-400 dark:text-gray-500 uppercase font-black">@Localizer["EmailLabel"]</p>
                            <p class="text-slate-700 dark:text-gray-200 text-sm font-medium">@Model.Email</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-4">
                        <div class="w-10 h-10 bg-slate-50 dark:bg-white/5 rounded-xl flex items-center justify-center text-blue-500 dark:text-blue-400">
                            <span class="material-icons-outlined text-xl">transgender</span>
                        </div>
                        <div>
                            <p class="text-[10px] text-slate-400 dark:text-gray-500 uppercase font-black">@Localizer["GenderLabel"]</p>
                            <p class="text-slate-700 dark:text-gray-200 text-sm font-medium">
                                @(Model.Gender.HasValue
                                                                ? Model.Gender.Value.GetLocalizedName(k => L.GetLocalizedHtmlString("EnumResource", k).Value)
                                                                : "Belirtilmemiş")
                            </p>
                        </div>
                    </div>
                    <div class="flex items-center gap-4">
                        <div class="w-10 h-10 bg-slate-50 dark:bg-white/5 rounded-xl flex items-center justify-center text-pink-500 dark:text-pink-400">
                            <span class="material-icons-outlined text-xl">celebration</span>
                        </div>
                        <div>
                            <p class="text-[10px] text-slate-400 dark:text-gray-500 uppercase font-black">@Localizer["BirthDateLabel"]</p>
                            <p class="text-slate-700 dark:text-gray-200 text-sm font-medium">@(Model.BirthDate.HasValue? Model.BirthDate.Value.ToString("dd MMM yyyy") : "Belirtilmemiş")</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-4">
                        <div class="w-10 h-10 bg-slate-50 dark:bg-white/5 rounded-xl flex items-center justify-center text-emerald-500 dark:text-emerald-400">
                            <span class="material-icons-outlined text-xl">event_available</span>
                        </div>
                        <div>
                            <p class="text-[10px] text-slate-400 dark:text-gray-500 uppercase font-black">@Localizer["RegistrationDateLabel"]</p>
                            <p class="text-slate-700 dark:text-gray-200 text-sm font-medium">@Model.CreatedAt.ToString("dd MMM yyyy")</p>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        @* --- ALERTLER --- *@
        @if (TempData["Success"] != null)
        {
            <div class="mb-6 p-4 rounded-2xl bg-emerald-500/10 border border-emerald-500/20 text-emerald-600 dark:text-emerald-400 flex items-center gap-3 animate-fade-in shadow-sm">
                <span class="material-icons-outlined">check_circle</span>
                <span class="text-sm font-bold">@TempData["Success"]</span>
            </div>
        }

        @* --- YETKİLENDİRME FORMU --- *@
        <div class="bg-white dark:bg-[#1e293b] border border-slate-200 dark:border-white/5 rounded-3xl shadow-sm dark:shadow-xl overflow-hidden transition-all">
            <div class="px-8 py-6 border-b border-slate-100 dark:border-white/5 bg-slate-50/50 dark:bg-white/5">
                <h3 class="text-xl font-black text-slate-800 dark:text-white flex items-center gap-3">
                    <span class="material-icons-outlined text-orange-500">verified_user</span>
                    @Localizer["EditRolesHeader"]
                </h3>
            </div>
            <form asp-action="ManageRoles" asp-controller="AdminRole" asp-area="Admin" method="post" class="p-8">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="UserId" />
                <input type="hidden" asp-for="UserName" />
                <input type="hidden" asp-for="Email" />
                <input type="hidden" asp-for="UserPhoto" />
                
                @if (!Model.AllRoles.Any())
                {
                    <div class="py-16 flex flex-col items-center justify-center border-2 border-dashed border-slate-200 dark:border-white/10 rounded-3xl bg-slate-50 dark:bg-white/5">
                        <span class="material-icons-outlined text-6xl text-slate-300 dark:text-gray-600 mb-4">lock_reset</span>
                        <p class="text-slate-400 dark:text-gray-400 font-bold">@Localizer["NoRolesDefined"]</p>
                    </div>
                }
                else
                {
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
                        @for (int i = 0; i < Model.AllRoles.Count; i++)
                        {
                            <div class="relative group">
                                <input type="hidden" asp-for="@Model.AllRoles[i].RoleId" />
                                <input type="hidden" asp-for="@Model.AllRoles[i].RoleName" />
                                <label for="role_@i" class="flex items-center p-5 rounded-2xl border border-slate-200 dark:border-white/5 bg-white dark:bg-white/5 hover:bg-slate-50 dark:hover:bg-white/10 hover:border-orange-500/50 cursor-pointer transition-all duration-300 group-has-[:checked]:border-orange-500 group-has-[:checked]:bg-orange-500/[0.03] dark:group-has-[:checked]:bg-orange-500/5 shadow-sm hover:shadow-md">
                                    <input type="checkbox" id="role_@i" asp-for="@Model.AllRoles[i].IsSelected" class="admin-role-checkbox w-6 h-6 rounded-lg bg-slate-100 dark:bg-gray-900 border-slate-300 dark:border-white/10 text-orange-600 focus:ring-orange-500 transition-all" />
                                    <div class="ml-4 flex flex-col">
                                        <span class="text-sm font-black text-slate-700 dark:text-white group-hover:text-orange-600 transition-colors">@Model.AllRoles[i].RoleName</span>
                                        <span class="text-[10px] font-mono text-slate-400 dark:text-gray-500">@Localizer["IdLabel"] @Model.AllRoles[i].RoleId.Substring(0, 8)</span>
                                    </div>
                                    <span class="material-icons-outlined ml-auto text-orange-500 opacity-0 group-has-[:checked]:opacity-100 transition-opacity">check_circle</span>
                                </label>
                            </div>
                        }
                    </div>
                }

                <div class="mt-12 flex flex-col-reverse sm:flex-row justify-end gap-4 pt-8 border-t border-slate-100 dark:border-white/5">
                    <a asp-action="UserList" asp-controller="Admin" asp-area="Admin" class="px-8 py-3.5 rounded-2xl bg-slate-100 dark:bg-white/5 text-slate-500 font-bold hover:bg-slate-200 transition-all text-center">@Localizer["Cancel"]</a>
                    <button type="submit" class="px-10 py-3.5 rounded-2xl bg-orange-600 hover:bg-orange-500 text-white font-black shadow-lg transform hover:-translate-y-1 transition-all flex items-center justify-center gap-2">
                        <span class="material-icons-outlined">save</span>
                        @Localizer["SaveChanges"]
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>