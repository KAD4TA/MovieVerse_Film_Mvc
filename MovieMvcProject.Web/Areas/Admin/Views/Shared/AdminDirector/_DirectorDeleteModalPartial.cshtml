@using MovieMvcProject.Web.Areas.Admin.Resources
@inject Microsoft.Extensions.Localization.IStringLocalizer<AdminActorDirectorResource> DirectorLocalizer

<div id="deleteModal" class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black/70 backdrop-blur-sm">
    <div class="bg-white dark:bg-surface-dark rounded-3xl max-w-md w-full mx-4 overflow-hidden shadow-2xl">
        <div class="p-8 text-center border-b border-gray-100 dark:border-white/10">
            <div class="mx-auto w-16 h-16 bg-red-100 dark:bg-red-900/30 rounded-2xl flex items-center justify-center mb-5">
                <span class="material-icons-outlined text-4xl text-red-600">warning</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 dark:text-white">@DirectorLocalizer["Director.List.DeleteConfirmTitle"]</h3>
            <p class="mt-2 text-gray-500 dark:text-gray-400">@DirectorLocalizer["Director.List.DeleteConfirmDescription"]</p>
        </div>
        <div class="p-8">
            <div class="flex items-center gap-4 bg-gray-50 dark:bg-black/20 p-4 rounded-2xl">
                <img id="modalPhoto" src="" class="w-14 h-14 rounded-2xl object-cover" alt="">
                <div>
                    <div id="modalName" class="font-bold text-lg"></div>
                    <div class="text-xs text-gray-500">Yönetmen</div>
                </div>
            </div>
        </div>
        <div class="p-6 border-t border-gray-100 dark:border-white/10 flex gap-3">
            <button onclick="closeDeleteModal()"
                    class="flex-1 py-4 rounded-2xl border border-gray-200 dark:border-white/10 font-semibold text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-white/5">
                @DirectorLocalizer["Director.List.Cancel"]
            </button>
            <form id="deleteForm" asp-area="Admin" asp-controller="AdminDirector" asp-action="Delete" method="post" class="flex-1">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="modalId" />
                <button type="submit"
                        class="w-full py-4 bg-red-600 hover:bg-red-700 text-white font-bold rounded-2xl flex items-center justify-center gap-2 transition-all">
                    <span class="material-icons-outlined">delete_forever</span>
                    @DirectorLocalizer["Director.List.DeleteConfirmAction"]
                </button>
            </form>
        </div>
    </div>
</div>