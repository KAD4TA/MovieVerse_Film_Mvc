@model MovieMvcProject.Application.Commons.PagedResult<MovieMvcProject.Web.Models.DirectorLookupViewModel>
@using MovieMvcProject.Application.Commons
@using MovieMvcProject.Web.Areas.Admin.Resources
@inject Microsoft.Extensions.Localization.IStringLocalizer<AdminActorDirectorResource> DirectorLocalizer
@{
    var totalItems = Model?.TotalCount ?? 0;
    var pageSize = Model?.PageSize ?? 10;
    var currentPage = Model?.PageNumber ?? 1;
    var totalPages = Model?.TotalPages ?? 1;
    var hasPreviousPage = Model?.HasPreviousPage ?? false;
    var hasNextPage = Model?.HasNextPage ?? false;
    var searchTerm = ViewBag.SearchTerm as string ?? "";
    
    int spread = 2;
    int startPage = Math.Max(1, currentPage - spread);
    int endPage = Math.Min(totalPages, currentPage + spread);
}

<div class="p-8 flex flex-col gap-8 w-full max-w-[1920px] mx-auto transition-colors duration-300">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
        <div>
            <h1 class="text-3xl font-black text-gray-900 dark:text-white tracking-tight flex items-center gap-3">
                <span class="w-2 h-8 bg-violet-600 rounded-full"></span>
                @DirectorLocalizer["Director.List.AllDirectors"]
            </h1>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-2 font-medium pl-5">
                @DirectorLocalizer["Director.List.TotalFound"]: <span class="text-gray-900 dark:text-white font-semibold">@totalItems</span>
            </p>
        </div>
        <div class="flex flex-col sm:flex-row items-center gap-4 w-full md:w-auto">
            <form asp-area="Admin" asp-controller="AdminDirector" asp-action="Index" method="get" class="w-full sm:w-auto flex-1">
                <div class="relative group">
                    <input type="search" name="searchTerm" value="@searchTerm"
                           placeholder="@DirectorLocalizer["Director.List.SearchPlaceholder"]..."
                           class="w-full sm:w-80 pl-11 pr-4 py-3 rounded-2xl bg-white dark:bg-surface-dark border border-gray-200 dark:border-white/10 text-sm focus:ring-2 focus:ring-violet-500 outline-none transition-all" />
                    <span class="material-icons-outlined absolute left-4 top-1/2 -translate-y-1/2 text-gray-400">search</span>
                </div>
            </form>
            <a asp-area="Admin" asp-controller="AdminDirector" asp-action="Create"
                   class="w-full sm:w-auto px-6 py-3 rounded-2xl bg-violet-600 hover:bg-violet-700 text-white font-bold text-sm shadow-lg flex items-center justify-center gap-2 transition-all">
                <span class="material-icons-outlined">add_circle</span>
                @DirectorLocalizer["Director.List.AddNew"]
            </a>
        </div>
    </div>

    <div class="bg-white dark:bg-surface-dark rounded-3xl border border-gray-200 dark:border-white/10 shadow-xl overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full text-left">
                <thead>
                    <tr class="border-b border-gray-100 dark:border-white/10 bg-gray-50 dark:bg-black/20">
                        <th class="px-8 py-6 text-xs font-black text-gray-400 uppercase tracking-widest">@DirectorLocalizer["Director.List.DirectorProfile"]</th>
                        <th class="px-8 py-6 text-xs font-black text-gray-400 uppercase tracking-widest">@DirectorLocalizer["Director.List.Name"]</th>
                        <th class="px-8 py-6 text-xs font-black text-gray-400 uppercase tracking-widest text-center">@DirectorLocalizer["Director.List.BirthDate"]</th>
                        <th class="px-8 py-6 text-xs font-black text-gray-400 uppercase tracking-widest text-center">@DirectorLocalizer["Director.List.MovieCount"]</th>
                        <th class="px-8 py-6 text-xs font-black text-gray-400 uppercase tracking-widest text-right">@DirectorLocalizer["Director.List.Actions"]</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 dark:divide-white/10">
                    @if (Model?.Items != null && Model.Items.Any())
                    {
                        foreach (var director in Model.Items)
                        {
                            <tr class="group hover:bg-gray-50 dark:hover:bg-white/5 transition-colors">
                                <td class="px-8 py-6 w-20">
                                    <img src="@(string.IsNullOrEmpty(director.PhotoUrl) ? "profie-images/default-profie.png" : director.PhotoUrl)"
                                         class="w-14 h-14 rounded-2xl object-cover border border-gray-200 dark:border-white/10 shadow-sm"
                                         onerror="this.src='/images/default-director.jpg';" alt="">
                                </td>
                                <td class="px-8 py-6">
                                    <div class="font-bold text-gray-900 dark:text-white">@director.Name</div>
                                    <div class="text-xs text-gray-400 font-mono mt-0.5">
                                        ID: #@director.Id.ToString().Substring(0, 8).ToUpper()
                                    </div>
                                </td>
                                <td class="px-8 py-6 text-center">
                                    <span class="inline-block px-4 py-1.5 bg-gray-100 dark:bg-white/5 text-sm font-medium rounded-2xl text-gray-600 dark:text-gray-400">
                                        @(director.BirthDate?.ToShortDateString() ?? "N/A")
                                    </span>
                                </td>
                                <td class="px-8 py-6 text-center">
                                    <div class="inline-flex items-center gap-2 px-5 py-2 bg-violet-100 dark:bg-violet-900/30 text-violet-700 dark:text-violet-300 rounded-2xl font-bold text-sm">
                                        <span class="material-icons-outlined text-base">movie</span>
                                        @director.MovieCount
                                    </div>
                                </td>
                                <td class="px-8 py-6 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        <a asp-action="Edit" asp-route-id="@director.Id"
                                               class="flex items-center justify-center w-10 h-10 rounded-2xl bg-blue-100 dark:bg-blue-900/30 text-blue-600 hover:bg-blue-600 hover:text-white transition-all">
                                            <span class="material-icons-outlined text-xl">edit</span>
                                        </a>
                                        <button type="button"
                                                onclick="openDeleteModal('@director.Id', '@director.Name', '@director.PhotoUrl')"
                                                class="flex items-center justify-center w-10 h-10 rounded-2xl bg-red-100 dark:bg-red-900/30 text-red-600 hover:bg-red-600 hover:text-white transition-all">
                                            <span class="material-icons-outlined text-xl">delete</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-20 text-gray-400 text-lg">
                                @DirectorLocalizer["Director.List.NoDirectorsFound"]
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="px-8 py-5 border-t border-gray-100 dark:border-white/10 bg-gray-50 dark:bg-black/20 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm">
            <span class="text-gray-500">
                @DirectorLocalizer["Director.List.Page"] <span class="font-semibold text-gray-900 dark:text-white">@currentPage</span> / @totalPages
            </span>
            <nav class="flex items-center gap-1.5">
                <a asp-action="Index"
                       asp-route-pageNumber="@(currentPage - 1)"
                       asp-route-searchTerm="@searchTerm"
                       asp-route-pageSize="@pageSize"
                       class="w-10 h-10 flex items-center justify-center rounded-2xl border border-gray-200 dark:border-white/10 text-gray-400 hover:text-violet-600 hover:border-violet-300 transition-all @( !hasPreviousPage ? "opacity-40 pointer-events-none" : "" )">
                    <span class="material-icons-outlined">chevron_left</span>
                </a>
                
                @for (int i = startPage; i <= endPage; i++)
                {
                    <a asp-action="Index"
                           asp-route-pageNumber="@i"
                           asp-route-searchTerm="@searchTerm"
                           asp-route-pageSize="@pageSize"
                           class="w-10 h-10 flex items-center justify-center rounded-2xl font-bold transition-all @(i == currentPage ? "bg-violet-600 text-white shadow-lg" : "border border-gray-200 dark:border-white/10 hover:bg-gray-50 dark:hover:bg-white/5")">
                        @i
                    </a>
                }
                
                <a asp-action="Index"
                       asp-route-pageNumber="@(currentPage + 1)"
                       asp-route-searchTerm="@searchTerm"
                       asp-route-pageSize="@pageSize"
                       class="w-10 h-10 flex items-center justify-center rounded-2xl border border-gray-200 dark:border-white/10 text-gray-400 hover:text-violet-600 hover:border-violet-300 transition-all @( !hasNextPage ? "opacity-40 pointer-events-none" : "" )">
                    <span class="material-icons-outlined">chevron_right</span>
                </a>
            </nav>
        </div>
    </div>
</div>