@using MovieMvcProject.Web.Areas.Admin.Resources
@inject Microsoft.Extensions.Localization.IStringLocalizer<AdminActorDirectorResource> ActorLocalizer

<div id="deleteModal" class="fixed inset-0 z-[100] hidden" aria-modal="true">
    <div class="fixed inset-0 bg-black/60 backdrop-blur-md transition-opacity" onclick="closeDeleteModal()"></div>
    <div class="flex min-h-screen items-center justify-center p-4">
        <div class="relative w-full max-w-lg bg-white dark:bg-surface-dark rounded-3xl border border-gray-200 dark:border-white/10 shadow-2xl transform transition-all animate-modal-in overflow-hidden">
            <div class="relative bg-gradient-to-b from-red-500/10 to-transparent p-6 text-center border-b border-gray-100 dark:border-white/5">
                <div class="mx-auto flex items-center justify-center h-16 w-16 rounded-full bg-red-500/10 border border-red-500/20 mb-3 shadow-[0_0_15px_rgba(239,68,68,0.2)]">
                    <span class="material-icons-outlined text-3xl text-red-500">warning</span>
                </div>
                <h2 class="text-xl font-black text-gray-900 dark:text-white">@ActorLocalizer["List.DeleteConfirmTitle"]</h2>
                <p class="text-red-500 dark:text-red-400 text-sm mt-1 font-medium">@ActorLocalizer["List.DeleteConfirmDescription"]</p>
            </div>
            <div class="p-6">
                <div class="flex gap-4 items-center bg-gray-50 dark:bg-black/20 p-4 rounded-2xl border border-gray-100 dark:border-white/5">
                    <img id="a-avatar" src="" class="w-16 h-16 object-cover rounded-full shadow-lg bg-white dark:bg-surface-dark border border-gray-200 dark:border-white/10" alt="Avatar">
                    <div class="flex flex-col gap-1.5">
                        <h3 id="a-name" class="text-lg font-bold text-gray-900 dark:text-white leading-tight"></h3>
                        <div class="flex items-center gap-2 text-xs text-gray-500 dark:text-gray-400">
                            <span class="flex items-center gap-1">
                                <span class="material-icons-outlined text-[10px]">calendar_today</span> <span id="a-birthdate"></span>
                            </span>
                        </div>
                        <div class="inline-flex items-center gap-1 text-yellow-500 text-xs font-bold">
                            <span class="material-icons-outlined text-[10px]">movie</span>
                            <span id="a-moviecount"></span>
                        </div>
                    </div>
                </div>
                <p class="mt-6 text-center text-gray-500 dark:text-gray-400 text-sm leading-relaxed">
                    <span id="a-confirm-text" class="font-bold text-gray-900 dark:text-white"></span>
                    @ActorLocalizer["Delete.ConfirmBody"]
                    <br><span class="text-red-500 font-bold">@ActorLocalizer["Delete.Irreversible"]</span>
                </p>
            </div>
            <div class="px-6 pb-6 pt-2 flex flex-col sm:flex-row gap-3">
                <button type="button" onclick="closeDeleteModal()" class="flex-1 px-4 py-3 rounded-xl border border-gray-200 dark:border-white/10 bg-gray-50 dark:bg-white/5 font-bold text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-white/10 hover:text-gray-900 dark:hover:text-white transition-all text-sm">
                    @ActorLocalizer["List.Cancel"]
                </button>
                <form asp-action="Delete" asp-controller="AdminActor" method="post" class="flex-1">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="a-id-input" value="" />
                    <button type="submit" class="w-full px-4 py-3 rounded-xl bg-red-600 hover:bg-red-700 text-white font-bold shadow-[0_0_20px_rgba(220,38,38,0.4)] hover:shadow-[0_0_30px_rgba(220,38,38,0.6)] transition-all flex items-center justify-center gap-2 text-sm">
                        <span class="material-icons-outlined text-lg">delete_forever</span>
                        @ActorLocalizer["List.DeleteConfirmAction"]
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>