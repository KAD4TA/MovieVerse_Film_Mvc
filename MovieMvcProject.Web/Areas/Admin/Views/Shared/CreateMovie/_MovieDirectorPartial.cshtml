@model MovieCreateUpdateViewModel
@using Microsoft.Extensions.Localization
@using MovieMvcProject.Web.Areas.Admin.Models
@using MovieMvcProject.Web.Areas.Admin.Resources
@inject IStringLocalizer<AdminResource> Localizer

<link rel="stylesheet" href="~/css/admin/movie-form.css" asp-append-version="true" />

<section class="form-glass rounded-2xl shadow-sm dark:shadow-none h-full flex flex-col">
    <div class="px-6 py-4 bg-slate-50 dark:bg-white/5 border-b border-slate-200 dark:border-white/5 flex items-center gap-2">
        <span class="material-symbols-outlined text-yellow-500 text-lg">movie_filter</span>
        <h2 class="font-bold uppercase tracking-wider text-sm">@Localizer["Section.Director"]</h2>
    </div>
    <div class="p-6 flex-1 flex flex-col">
        <div id="selected-director-card" class="hidden mb-4 p-4 rounded-xl bg-yellow-500/10 border border-yellow-500/20 items-center justify-between"></div>
        <div id="director-selection-area" class="relative">
            <span class="material-symbols-outlined absolute left-3 top-3.5 text-slate-400 dark:text-white/30">search</span>
            <input type="text" id="director-search-input" class="w-full bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl pl-10 pr-4 py-3 text-sm text-slate-900 dark:text-white focus:outline-none placeholder-slate-400 dark:placeholder-white/30" placeholder="@Localizer["Placeholder.DirectorSearch"]" autocomplete="off" />
            <div id="d-results" class="search-results-container bg-white dark:bg-[#171717] border border-slate-200 dark:border-white/10 shadow-2xl" style="display:none;">
                <div id="d-results-list" class="max-h-48 overflow-y-auto custom-scrollbar"></div>
                <div id="d-add-new-trigger" class="p-3 border-t border-slate-100 dark:border-white/10 bg-yellow-500/5 hover:bg-yellow-500/10 cursor-pointer flex items-center gap-2 text-yellow-600 dark:text-yellow-500 text-xs font-bold uppercase transition-all">
                    <span class="material-symbols-outlined text-sm">person_add</span>
                    <span>"<span class="search-term-display"></span>" @Localizer["Text.NewRecordFor"]</span>
                </div>
            </div>
        </div>
        <div id="manual-director-form" class="mt-4 p-4 border border-dashed border-yellow-500/30 rounded-xl hidden bg-yellow-500/5 space-y-3">
            <div class="flex justify-between items-center mb-1">
                <p class="text-[10px] font-black text-yellow-600 dark:text-yellow-500 uppercase tracking-widest">@Localizer["Section.NewDirector"]</p>
                <button type="button" onclick="closeManualForm('director')" class="text-slate-400 dark:text-white/20 hover:text-red-500"><span class="material-symbols-outlined text-sm">close</span></button>
            </div>
            <input type="text" id="new-d-name" class="w-full bg-white dark:bg-black/40 border border-slate-200 dark:border-white/10 rounded-lg px-3 py-2 text-sm text-slate-900 dark:text-white" placeholder="@Localizer["Placeholder.FullName"]" />
            <input type="url" id="new-d-photo" class="w-full bg-white dark:bg-black/40 border border-slate-200 dark:border-white/10 rounded-lg px-3 py-2 text-sm text-slate-900 dark:text-white" placeholder="@Localizer["Placeholder.PhotoUrl"]" />
            <input type="text" id="new-d-birthplace" class="w-full bg-white dark:bg-black/40 border border-slate-200 dark:border-white/10 rounded-lg px-3 py-2 text-sm text-slate-900 dark:text-white" placeholder="@Localizer["Placeholder.BirthPlace"]" />
            <div class="grid grid-cols-2 gap-3">
                <input type="number" id="new-d-height" class="w-full bg-white dark:bg-black/40 border border-slate-200 dark:border-white/10 rounded-lg px-3 py-2 text-sm text-slate-900 dark:text-white" placeholder="@Localizer["Placeholder.HeightCm"]" />
                <input type="date" id="new-d-birthdate" class="w-full bg-white dark:bg-black/40 border border-slate-200 dark:border-white/10 rounded-lg px-3 py-2 text-sm text-slate-900 dark:text-white dark:[&::-webkit-calendar-picker-indicator]:invert" />
            </div>
            <button type="button" onclick="setNewDirector()" class="w-full py-2.5 bg-yellow-500 text-black text-xs font-black rounded-lg hover:brightness-110">@Localizer["Button.PrepareForSystem"]</button>
        </div>
    </div>
</section>