@model MovieCreateUpdateViewModel

@using MovieMvcProject.Domain.Enums
@using MovieMvcProject.Web.Areas.Admin.Models
@using MovieMvcProject.Web.Areas.Admin.Resources
@using MovieMvcProject.Web.Helpers
@using Microsoft.Extensions.Localization
@using System.Web

@inject IStringLocalizer<AdminResource> Localizer
@inject MovieMvcProject.Application.Interfaces.ILocalization.ILocalizationService LocalizationService

@{
    var categoryItems = EnumSelectListHelper.GetLocalizedEnumSelectList<Category>(LocalizationService);
}

<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />

<link rel="stylesheet" href="~/css/admin/movie-form.css" asp-append-version="true" />

<form asp-area="Admin" asp-controller="Admin" asp-action="@(Model.MovieId.HasValue ? "EditMovie" : "CreateMovie")"
      method="post" id="movieForm" class="max-w-[1400px] mx-auto p-4 lg:p-8 pb-24 space-y-8 text-slate-900 dark:text-white transition-colors duration-300">

    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="MovieId" />

    <input type="hidden" asp-for="ExistingDirectorId" id="ExistingDirectorId" />
    <input type="hidden" asp-for="ExistingDirectorName" id="ExistingDirectorName" />
    <input type="hidden" asp-for="DirectorName" id="DirectorName" />
    <input type="hidden" asp-for="DirectorPhotoUrl" id="DirectorPhotoUrl" />
    <input type="hidden" asp-for="DirectorBirthPlace" id="DirectorBirthPlace" />
    <input type="hidden" asp-for="DirectorHeightCm" id="DirectorHeightCm" />
    <input type="hidden" asp-for="DirectorBirthDate" id="DirectorBirthDate" />

    <!-- HEADER -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 border-b border-slate-200 dark:border-white/5 pb-8">
        <div>
            <nav class="flex mb-2 text-xs font-medium opacity-50 uppercase tracking-widest text-slate-500 dark:text-slate-400">
                <span>@Localizer["Breadcrumb.Admin"]</span><span class="mx-2">/</span><span>@Localizer["Breadcrumb.Movies"]</span>
            </nav>
            <h1 class="text-4xl font-black tracking-tight">
                @(Model.MovieId.HasValue ? Localizer["Movie.Form.Title.Edit"] : Localizer["Movie.Form.Title.Create"])
            </h1>
        </div>
        <div class="flex items-center gap-4">
            <a asp-action="MovieList" class="px-6 py-3 rounded-xl font-semibold text-sm transition-all bg-slate-100 hover:bg-slate-200 dark:bg-white/5 border border-slate-200 dark:border-white/10 text-slate-600 dark:text-white/80 hover:text-slate-900 dark:hover:text-white">
                @Localizer["Button.Cancel"]
            </a>
            <button type="submit" class="px-8 py-3 rounded-xl bg-yellow-500 hover:bg-yellow-400 text-black font-bold shadow-2xl shadow-yellow-500/20 transition-all flex items-center gap-2 transform active:scale-95">
                <span class="material-symbols-outlined">save</span> @Localizer["Button.Save"]
            </button>
        </div>
    </div>

    <div asp-validation-summary="ModelOnly" class="empty:hidden p-4 rounded-xl bg-red-500/10 border border-red-500/20 text-red-500 dark:text-red-400 text-sm font-medium flex items-center gap-3">
        <span class="material-symbols-outlined">error</span>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        <!-- SOL KOLON -->
        <div class="lg:col-span-8 space-y-8">

            <!-- TEMEL BİLGİLER (Türkçe + İngilizce) -->
            <section class="form-glass rounded-2xl overflow-hidden shadow-sm dark:shadow-none">
                <div class="px-6 py-4 bg-slate-50 dark:bg-white/5 border-b border-slate-200 dark:border-white/5 flex items-center gap-2">
                    <span class="material-symbols-outlined text-yellow-500">translate</span>
                    <h2 class="font-bold uppercase tracking-wider text-sm">@Localizer["Section.TranslationAndContent"]</h2>
                </div>
                <div class="p-6 space-y-6">
                    <!-- Türkçe -->
                    <div class="space-y-4">
                        <div class="space-y-2">
                            <label class="text-xs font-bold text-slate-500 dark:text-white/60 uppercase ml-1">@Localizer["Label.TurkishTitle"]</label>
                            <input asp-for="TurkishTitle" class="w-full bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl px-4 py-3 text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-white/20 focus:outline-none input-transition" placeholder="@Localizer["Placeholder.ExampleBaslangic"]" />
                            <span asp-validation-for="TurkishTitle" class="text-[10px] text-red-500 font-bold uppercase"></span>
                        </div>
                        <div class="space-y-2">
                            <label class="text-xs font-bold text-slate-500 dark:text-white/60 uppercase ml-1">@Localizer["Label.TurkishDescription"]</label>
                            <textarea asp-for="TurkishDescription" rows="3" class="w-full bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl px-4 py-3 text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-white/20 focus:outline-none input-transition resize-none"></textarea>
                            <span asp-validation-for="TurkishDescription" class="text-[10px] text-red-500 font-bold uppercase"></span>
                        </div>
                    </div>
                    <div class="h-px bg-slate-200 dark:bg-white/5"></div>
                    <!-- İngilizce -->
                    <div class="space-y-4">
                        <div class="space-y-2">
                            <label class="text-xs font-bold text-slate-500 dark:text-white/60 uppercase ml-1">@Localizer["Label.EnglishTitle"]</label>
                            <input asp-for="EnglishTitle" class="w-full bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl px-4 py-3 text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-white/20 focus:outline-none input-transition" placeholder="@Localizer["Placeholder.ExampleInception"]" />
                            <span asp-validation-for="EnglishTitle" class="text-[10px] text-red-500 font-bold uppercase"></span>
                        </div>
                        <div class="space-y-2">
                            <label class="text-xs font-bold text-slate-500 dark:text-white/60 uppercase ml-1">@Localizer["Label.EnglishDescription"]</label>
                            <textarea asp-for="EnglishDescription" rows="3" class="w-full bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl px-4 py-3 text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-white/20 focus:outline-none input-transition resize-none"></textarea>
                            <span asp-validation-for="EnglishDescription" class="text-[10px] text-red-500 font-bold uppercase"></span>
                        </div>
                    </div>
                </div>
            </section>

            <!-- TEKNİK DETAYLAR -->
            <section class="form-glass rounded-2xl shadow-sm dark:shadow-none">
                <div class="px-6 py-4 bg-slate-50 dark:bg-white/5 border-b border-slate-200 dark:border-white/5 flex items-center gap-2">
                    <span class="material-symbols-outlined text-yellow-500">settings_applications</span>
                    <h2 class="font-bold uppercase tracking-wider text-sm">@Localizer["Section.TechnicalDetails"]</h2>
                </div>
                <div class="p-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
                        <div class="space-y-2">
                            <label class="text-xs font-bold text-slate-500 dark:text-white/60 uppercase">@Localizer["Label.Category"]</label>
                            <div class="relative">
                                <select asp-for="Category" asp-items="categoryItems" class="w-full bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl px-4 py-3 text-slate-900 dark:text-white focus:outline-none appearance-none cursor-pointer [&>option]:text-slate-900 [&>option]:bg-white dark:[&>option]:text-white dark:[&>option]:bg-[#171717]">
                                    <option value="">@Localizer["Option.Select"]</option>
                                </select>
                                <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400 dark:text-white/40">expand_more</span>
                            </div>
                            <span asp-validation-for="Category" class="text-[10px] text-red-500 font-bold uppercase"></span>
                        </div>
                        <div class="space-y-2">
                            <label class="text-xs font-bold text-slate-500 dark:text-white/60 uppercase">@Localizer["Label.ProductionYear"]</label>
                            <input asp-for="Year" type="number" class="w-full bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl px-4 py-3 text-slate-900 dark:text-white focus:outline-none" placeholder="2024" />
                            <span asp-validation-for="Year" class="text-[10px] text-red-500 font-bold uppercase"></span>
                        </div>
                        <div class="space-y-2">
                            <label class="text-xs font-bold text-slate-500 dark:text-white/60 uppercase">@Localizer["Label.DurationMinutes"]</label>
                            <input asp-for="DurationMinutes" type="number" class="w-full bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl px-4 py-3 text-slate-900 dark:text-white focus:outline-none" placeholder="120" />
                            <span asp-validation-for="DurationMinutes" class="text-[10px] text-red-500 font-bold uppercase"></span>
                        </div>
                        <div class="space-y-2">
                            <label class="text-xs font-bold text-slate-500 dark:text-white/60 uppercase">@Localizer["Label.ImdbRating"]</label>
                            <input asp-for="Rating" step="0.1" type="number" class="w-full bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl px-4 py-3 text-slate-900 dark:text-white focus:outline-none" placeholder="8.5" />
                            <span asp-validation-for="Rating" class="text-[10px] text-red-500 font-bold uppercase"></span>
                        </div>
                    </div>
                    <div class="space-y-2">
                        <label class="text-xs font-bold text-slate-500 dark:text-white/60 uppercase flex items-center gap-2">
                            <span class="material-symbols-outlined text-sm">videocam</span> @Localizer["Label.TrailerUrl"]
                        </label>
                        <input asp-for="VideoUrl" type="url" class="w-full bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl px-4 py-3 text-slate-900 dark:text-white text-sm focus:outline-none font-mono" placeholder="https://youtube.com/..." />
                        <span asp-validation-for="VideoUrl" class="text-[10px] text-red-500 font-bold uppercase"></span>
                    </div>
                </div>
            </section>

            <!-- YÖNETMEN + OYUNCULAR -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                @await Html.PartialAsync("CreateMovie/_MovieDirectorPartial", Model)
                @await Html.PartialAsync("CreateMovie/_MovieActorsPartial", Model)
            </div>
        </div>

        <!-- SAĞ KOLON - POSTER -->
        <div class="lg:col-span-4">
            @await Html.PartialAsync("CreateMovie/_MoviePosterPartial", Model)
        </div>
    </div>
</form>