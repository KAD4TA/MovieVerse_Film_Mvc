@model MovieCreateUpdateViewModel
@using Microsoft.Extensions.Localization
@using MovieMvcProject.Web.Areas.Admin.Models
@using MovieMvcProject.Web.Areas.Admin.Resources
@inject IStringLocalizer<AdminResource> Localizer

<link rel="stylesheet" href="~/css/admin/movie-form.css" asp-append-version="true" />

<section class="form-glass rounded-2xl shadow-sm dark:shadow-none h-full flex flex-col">
    <div class="px-6 py-4 bg-slate-50 dark:bg-white/5 border-b border-slate-200 dark:border-white/5 flex justify-between items-center">
        <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-yellow-500 text-lg">groups</span>
            <h2 class="font-bold uppercase tracking-wider text-sm">@Localizer["Section.Actors"]</h2>
        </div>
        <span id="cast-count" class="text-[10px] bg-yellow-500 text-black px-2 py-0.5 rounded-full font-bold">0</span>
    </div>
    <div class="p-6 flex-1 flex flex-col">
        <div id="cast-list" class="space-y-2 max-h-64 overflow-y-auto pr-2 custom-scrollbar mb-4"></div>
        <div id="actor-selection-area" class="relative mt-auto">
            <span class="material-symbols-outlined absolute left-3 top-3.5 text-slate-400 dark:text-white/30 text-sm">search</span>
            <input type="text" id="actor-search-input" class="w-full bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl pl-10 pr-4 py-3 text-sm text-slate-900 dark:text-white focus:outline-none placeholder-slate-400 dark:placeholder-white/30" placeholder="@Localizer["Placeholder.ActorSearch"]" autocomplete="off" />
            <div id="a-results" class="search-results-container bottom-full mb-2 top-auto bg-white dark:bg-[#171717] border border-slate-200 dark:border-white/10 shadow-2xl" style="display:none;">
                <div id="a-results-list" class="max-h-48 overflow-y-auto custom-scrollbar"></div>
                <div id="a-add-new-trigger" class="p-3 border-t border-slate-100 dark:border-white/10 bg-yellow-500/5 hover:bg-yellow-500/10 cursor-pointer flex items-center gap-2 text-yellow-600 dark:text-yellow-500 text-xs font-bold uppercase transition-all">
                    <span class="material-symbols-outlined text-sm">person_add</span>
                    <span>"<span class="search-term-display-actor"></span>" @Localizer["Text.NewRecordFor"]</span>
                </div>
            </div>
        </div>
        <div id="manual-actor-form" class="mt-4 p-4 border border-dashed border-yellow-500/30 rounded-xl hidden bg-yellow-500/5 space-y-3">
            <div class="flex justify-between items-center mb-1">
                <p class="text-[10px] font-black text-yellow-600 dark:text-yellow-500 uppercase tracking-widest">@Localizer["Section.NewActorCard"]</p>
                <button type="button" onclick="closeManualForm('actor')" class="text-slate-400 dark:text-white/20 hover:text-red-500"><span class="material-symbols-outlined text-sm">close</span></button>
            </div>
            <input type="text" id="new-a-name" class="w-full bg-white dark:bg-black/40 border border-slate-200 dark:border-white/10 rounded-lg px-3 py-2 text-sm text-slate-900 dark:text-white" placeholder="@Localizer["Placeholder.ActorName"]" />
            <input type="url" id="new-a-photo" class="w-full bg-white dark:bg-black/40 border border-slate-200 dark:border-white/10 rounded-lg px-3 py-2 text-sm text-slate-900 dark:text-white" placeholder="@Localizer["Placeholder.PhotoUrl"]" />
            <input type="text" id="new-a-birthplace" class="w-full bg-white dark:bg-black/40 border border-slate-200 dark:border-white/10 rounded-lg px-3 py-2 text-sm text-slate-900 dark:text-white" placeholder="@Localizer["Placeholder.BirthPlace"]" />
            <div class="grid grid-cols-2 gap-3">
                <input type="number" id="new-a-height" class="w-full bg-white dark:bg-black/40 border border-slate-200 dark:border-white/10 rounded-lg px-3 py-2 text-sm text-slate-900 dark:text-white" placeholder="@Localizer["Placeholder.HeightCm"]" />
                <input type="date" id="new-a-birthdate" class="w-full bg-white dark:bg-black/40 border border-slate-200 dark:border-white/10 rounded-lg px-3 py-2 text-sm text-slate-900 dark:text-white dark:[&::-webkit-calendar-picker-indicator]:invert" />
            </div>
            <button type="button" onclick="setManualActor()" class="w-full py-2.5 bg-yellow-500 text-black text-xs font-black rounded-lg hover:brightness-110">@Localizer["Button.AddToList"]</button>
        </div>
    </div>
</section>