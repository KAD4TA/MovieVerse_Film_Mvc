@model MovieMvcProject.Web.Areas.Admin.Models.DashboardViewModel
@using MovieMvcProject.Application.DTOs.LogDto
@using Microsoft.Extensions.Localization
@using MovieMvcProject.Web.Areas.Admin.Resources
@inject IStringLocalizer<AdminResource> AdminLocalizer

<section class="bg-white dark:bg-[#1e293b] rounded-3xl border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm mt-8">
    <div class="p-6 border-b border-slate-200 dark:border-slate-800 flex justify-between items-center bg-slate-50/50 dark:bg-slate-800/30">
        <h2 class="text-lg font-bold dark:text-white">@AdminLocalizer["Dashboard.RecentSystemLogs"]</h2>
        <a asp-area="Admin" asp-controller="Log" asp-action="List" class="text-neon-blue text-sm font-medium hover:text-neon-cyan transition-colors flex items-center gap-1 group">
            @AdminLocalizer["Dashboard.ViewAll"] <span class="group-hover:translate-x-1 transition-transform">→</span>
        </a>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left">
            <thead class="text-[10px] uppercase text-slate-400 font-black tracking-widest border-b border-slate-100 dark:border-slate-800">
                <tr>
                    <th class="px-8 py-4">@AdminLocalizer["Dashboard.Timestamp"]</th>
                    <th class="px-8 py-4">@AdminLocalizer["Dashboard.Level"]</th>
                    <th class="px-8 py-4">@AdminLocalizer["Dashboard.EventMessage"]</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                @foreach (var log in Model.RecentLogs ?? new List<LogDto>())
                {
                    <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/40 transition-colors group">
                        <td class="px-8 py-4 font-mono text-xs text-slate-400">@log.TimeStamp.ToString("HH:mm:ss")</td>
                        <td class="px-8 py-4">
                            @{
                                var statusClass = log.Level switch { "Error" => "bg-red-500/10 text-red-500 border-red-500/20", "Warning" => "bg-amber-500/10 text-amber-500 border-amber-500/20", _ => "bg-emerald-500/10 text-emerald-500 border-emerald-500/20" };
                            }
                            <span class="px-3 py-1 rounded-full text-[10px] font-bold border @statusClass">@log.Level.ToUpper()</span>
                        </td>
                        <td class="px-8 py-4 text-sm text-slate-500 dark:text-slate-400 group-hover:text-slate-900 dark:group-hover:text-white transition-colors">@log.Message</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>