@model MovieMvcProject.Web.Areas.Admin.Models.DashboardViewModel
@using Microsoft.Extensions.Localization
@using MovieMvcProject.Web.Areas.Admin.Resources
@inject IStringLocalizer<AdminResource> AdminLocalizer

<div class="bg-white dark:bg-[#1e293b] rounded-2xl border border-slate-200 dark:border-slate-800 p-6 shadow-xl flex flex-col transition-all duration-300">
    <h2 class="text-xl font-semibold dark:text-white mb-8">@AdminLocalizer["Dashboard.GenreDistribution"]</h2>
    <div class="flex-1 flex items-center justify-center w-full max-w-[350px] aspect-square mx-auto">
        <canvas id="genreChart"></canvas>
    </div>
</div>