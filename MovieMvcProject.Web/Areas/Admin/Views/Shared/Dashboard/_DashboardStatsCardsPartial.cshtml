@model MovieMvcProject.Web.Areas.Admin.Models.DashboardViewModel
@using Microsoft.Extensions.Localization
@using MovieMvcProject.Web.Areas.Admin.Resources
@inject IStringLocalizer<AdminResource> AdminLocalizer

<section class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-5 gap-6">
    <a asp-area="Admin" asp-controller="Admin" asp-action="MovieList" class="block bg-white dark:bg-[#1e293b] rounded-2xl p-6 glow-purple relative overflow-hidden group transition-all duration-300 hover:scale-[1.03] hover:-translate-y-1 hover:border-neon-purple hover:shadow-lg hover:shadow-neon-purple/20 cursor-pointer">
        <div class="flex justify-between items-start relative z-10">
            <div>
                <p class="text-slate-500 dark:text-slate-400 text-sm font-medium">@AdminLocalizer["Dashboard.TotalMovies"]</p>
                <h2 class="text-3xl font-bold dark:text-white mt-1">@(Model.Summary?.TotalMovies.ToString("N0") ?? "0")</h2>
            </div>
            <div class="w-16 h-10 opacity-50"><svg viewBox="0 0 100 50" class="w-full h-full"><path d="M0 40 Q 25 35, 40 25 T 100 10" fill="none" stroke="#a855f7" stroke-width="4" class="animate-path" /></svg></div>
        </div>
    </a>
    <a asp-area="Admin" asp-controller="Admin" asp-action="UserList" class="block bg-white dark:bg-[#1e293b] rounded-2xl p-6 glow-blue relative overflow-hidden group transition-all duration-300 hover:scale-[1.03] hover:-translate-y-1 hover:border-neon-blue hover:shadow-lg hover:shadow-neon-blue/20 cursor-pointer">
        <div class="flex justify-between items-start relative z-10">
            <div>
                <p class="text-slate-500 dark:text-slate-400 text-sm font-medium">@AdminLocalizer["Dashboard.TotalUsers"]</p>
                <h2 class="text-3xl font-bold dark:text-white mt-1">@(Model.Summary?.TotalUsers.ToString("N0") ?? "0")</h2>
            </div>
            <div class="w-16 h-10 opacity-50"><svg viewBox="0 0 100 50" class="w-full h-full"><path d="M0 40 L 20 30 L 40 35 L 70 15 L 100 5" fill="none" stroke="#3b82f6" stroke-width="4" class="animate-path" /></svg></div>
        </div>
    </a>
    <a asp-area="Admin" asp-controller="Log" asp-action="List" class="block bg-white dark:bg-[#1e293b] rounded-2xl p-6 glow-green relative overflow-hidden group transition-all duration-300 hover:scale-[1.03] hover:-translate-y-1 hover:border-neon-green hover:shadow-lg hover:shadow-neon-green/20 cursor-pointer">
        <div class="flex justify-between items-start relative z-10">
            <div>
                <p class="text-slate-500 dark:text-slate-400 text-sm font-medium">@AdminLocalizer["Dashboard.TotalVisitors"]</p>
                <h2 class="text-3xl font-bold dark:text-white mt-1">@(Model.Summary?.TotalVisitors.ToString("N0") ?? "0")</h2>
            </div>
            <div class="w-16 h-10 opacity-50"><svg viewBox="0 0 100 50" class="w-full h-full"><path d="M0 40 L 20 30 L 40 35 L 70 15 L 100 5" fill="none" stroke="#10b981" stroke-width="4" class="animate-path" /></svg></div>
        </div>
    </a>
    <a asp-area="Admin" asp-controller="Admin" asp-action="EditUser" asp-route-id="@Model.Summary?.LatestUserId" class="flex bg-white dark:bg-[#1e293b] rounded-2xl p-6 glow-cyan items-center gap-4 group transition-all duration-300 hover:scale-[1.03] hover:-translate-y-1 hover:border-neon-cyan hover:shadow-lg hover:shadow-neon-cyan/20 cursor-pointer">
        <div class="w-14 h-14 rounded-full border-2 border-neon-cyan/50 p-0.5 shadow-lg shadow-neon-cyan/10 flex-shrink-0">
            <img src="@(Model.Summary?.LatestUserNamePhoto ?? "/profile-images/default-profile.png")" class="w-full h-full rounded-full object-cover" />
        </div>
        <div class="truncate">
            <p class="text-slate-500 dark:text-slate-400 text-xs font-medium uppercase tracking-wider">@AdminLocalizer["Dashboard.NewMember"]</p>
            <h3 class="font-bold dark:text-white truncate">@(Model.Summary?.LatestUserName ?? "Guest")</h3>
        </div>
    </a>
    <a asp-area="Admin" asp-controller="AdminComments" asp-action="Index" class="flex bg-white dark:bg-[#1e293b] rounded-2xl p-6 glow-pink items-center gap-4 group transition-all duration-300 hover:scale-[1.03] hover:-translate-y-1 hover:border-neon-pink hover:shadow-lg hover:shadow-neon-pink/20 cursor-pointer">
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-neon-pink/20 to-neon-purple/20 flex items-center justify-center border border-neon-pink/30 flex-shrink-0">
            <svg class="w-6 h-6 text-neon-pink" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
        </div>
        <div class="truncate">
            <p class="text-slate-500 dark:text-slate-400 text-xs font-medium uppercase tracking-wider">@AdminLocalizer["Dashboard.LatestFeedback"]</p>
            <p class="font-bold dark:text-white italic truncate text-sm">"@Model.Summary?.LatestCommentText"</p>
        </div>
    </a>
</section>