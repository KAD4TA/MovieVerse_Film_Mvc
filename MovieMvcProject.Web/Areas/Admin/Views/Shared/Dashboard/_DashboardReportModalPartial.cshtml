@model MovieMvcProject.Web.Areas.Admin.Models.DashboardViewModel
@using Microsoft.Extensions.Localization
@using MovieMvcProject.Web.Areas.Admin.Resources
@inject IStringLocalizer<AdminResource> AdminLocalizer

<div id="reportModal" class="modal opacity-0 pointer-events-none fixed w-full h-full top-0 left-0 flex items-center justify-center z-50">
    <div class="modal-overlay absolute w-full h-full bg-slate-900 opacity-50"></div>
    <div class="modal-container bg-white dark:bg-[#1e293b] w-11/12 md:max-w-3xl mx-auto rounded-xl shadow-2xl z-50 overflow-y-auto max-h-[90vh]">
        <div class="modal-content py-4 text-left px-6">
            <div class="flex justify-between items-center pb-3 border-b border-slate-200 dark:border-slate-700">
                <p class="text-2xl font-bold dark:text-white">@AdminLocalizer["Dashboard.AnalyticsReport"]</p>
                <div class="flex items-center gap-2">
                    <button onclick="downloadExcel()" class="px-3 py-1.5 text-xs font-bold rounded-lg bg-green-600 text-white hover:bg-green-700 transition-colors flex items-center gap-1 shadow-md">
                        <span class="material-symbols-outlined text-sm">download</span> @AdminLocalizer["Dashboard.DownloadXLSX"]
                    </button>
                    <div class="modal-close cursor-pointer p-1 rounded-full hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors" onclick="closeReportModal()">
                        <span class="material-symbols-outlined text-slate-500 hover:text-red-500">close</span>
                    </div>
                </div>
            </div>
            <div class="my-5">
                <p class="mb-4 text-sm text-slate-500 dark:text-slate-400">@AdminLocalizer["Dashboard.ReportFor"] <span id="reportType" class="font-bold text-slate-700 dark:text-slate-200 uppercase"></span></p>
                <div class="overflow-x-auto rounded-lg border border-slate-200 dark:border-slate-700">
                    <table class="w-full text-left" id="reportTable">
                        <thead class="bg-slate-50 dark:bg-slate-800 text-xs uppercase font-bold text-slate-500" id="reportTableHead"></thead>
                        <tbody class="divide-y divide-slate-100 dark:divide-slate-700" id="reportTableBody"></tbody>
                    </table>
                </div>
            </div>
            <div class="flex justify-end pt-2">
                <button onclick="closeReportModal()" class="px-4 py-2 bg-slate-200 dark:bg-slate-700 text-slate-700 dark:text-slate-300 rounded-lg hover:bg-slate-300 dark:hover:bg-slate-600 transition-colors">@AdminLocalizer["Dashboard.Close"]</button>
            </div>
        </div>
    </div>
</div>