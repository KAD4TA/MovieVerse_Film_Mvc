@using MovieMvcProject.Application.Commons
@using MovieMvcProject.Application.DTOs.ResponseDto
@using MovieMvcProject.Domain.Enums
@using Microsoft.Extensions.Localization
@using MovieMvcProject.Web.Areas.Admin.Resources

@model PagedResult<CommentDtoResponse>
@inject IStringLocalizer<AdminCommentResource> Localizer

@{
    ViewData["Title"] = Localizer["PageTitle"];
    Layout = "_LayoutAdmin";
    var searchTerm = ViewBag.SearchTerm as string;
    var selectedStatus = ViewBag.SelectedStatus as CommentStatus?;
}

@section Styles {
    <link href="~/css/admincomment/admincomment.css" rel="stylesheet" />
}

<div class="p-8 transition-colors duration-300">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
        <div>
            <h1 class="text-3xl font-black text-gray-900 dark:text-white tracking-tight">@Localizer["PageTitle"]</h1>
            <p class="text-gray-500 dark:text-gray-400 text-sm mt-1 font-medium">
                @Localizer["TotalComments", Model?.TotalCount ?? 0]
            </p>
        </div>
    </div>

    <div class="bg-white dark:bg-surface-dark border border-gray-200 dark:border-white/5 rounded-3xl p-6 mb-8 shadow-xl transition-colors">
        <form asp-action="Index" method="get" class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div class="md:col-span-2 relative">
                <span class="material-icons-outlined absolute left-4 top-1/2 -translate-y-1/2 text-gray-400">search</span>
                <input type="text" name="searchTerm" value="@searchTerm"
                       placeholder="@Localizer["SearchPlaceholder"]"
                       class="w-full pl-12 pr-4 py-3.5 bg-gray-50 dark:bg-background-dark border-0 rounded-2xl text-gray-900 dark:text-gray-200 focus:ring-2 focus:ring-primary/50 text-sm transition-all" />
            </div>
            <div class="relative">
                <select name="status" class="w-full px-4 py-3.5 bg-gray-50 dark:bg-background-dark border-0 rounded-2xl text-gray-900 dark:text-gray-200 focus:ring-2 focus:ring-primary/50 text-sm appearance-none cursor-pointer">
                    <option value="">@Localizer["AllStatuses"]</option>
                    <option value="0" selected="@(selectedStatus == CommentStatus.Pending)">@Localizer["Pending"]</option>
                    <option value="1" selected="@(selectedStatus == CommentStatus.Approved)">@Localizer["Approved"]</option>
                    <option value="2" selected="@(selectedStatus == CommentStatus.Rejected)">@Localizer["Rejected"]</option>
                </select>
                <span class="material-icons-outlined absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none">expand_more</span>
            </div>
            <button type="submit" class="bg-primary hover:bg-primary/80 text-white font-bold py-3.5 rounded-2xl transition-all flex items-center justify-center gap-2 shadow-lg shadow-primary/20">
                <span class="material-icons-outlined text-xl">filter_alt</span> @Localizer["Filter"]
            </button>
        </form>
    </div>

    <div id="bulk-toolbar" class="hidden fixed bottom-10 left-1/2 -translate-x-1/2 z-40 bg-white/90 dark:bg-surface-dark/90 backdrop-blur-2xl border border-primary/30 rounded-3xl p-4 shadow-2xl flex items-center gap-6 animate-bounce-subtle">
        <div class="pl-4 border-r border-gray-200 dark:border-white/10 pr-6">
            <p class="text-[10px] font-black uppercase tracking-widest text-primary"><span id="selected-count" class="text-lg">0</span> @Localizer["Selected"]</p>
        </div>
        <div class="flex gap-2">
            <button onclick="openConfirmModal(true, 'approve')" class="px-5 py-2.5 bg-green-500/10 hover:bg-green-500 text-green-600 hover:text-white rounded-xl text-xs font-bold transition-all border border-green-500/20">@Localizer["Approve"]</button>
            <button onclick="openConfirmModal(true, 'reject')" class="px-5 py-2.5 bg-orange-500/10 hover:bg-orange-500 text-orange-600 hover:text-white rounded-xl text-xs font-bold transition-all border border-orange-500/20">@Localizer["Reject"]</button>
            <button onclick="openConfirmModal(true, 'delete')" class="px-5 py-2.5 bg-red-500/10 hover:bg-red-500 text-red-600 hover:text-white rounded-xl text-xs font-bold transition-all border border-red-500/20">@Localizer["Delete"]</button>
        </div>
    </div>

    <div class="bg-white dark:bg-surface-dark border border-gray-200 dark:border-white/5 rounded-3xl shadow-xl overflow-hidden mb-6 transition-colors">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse" id="commentsTable">
                <thead>
                    <tr class="bg-gray-50 dark:bg-white/5 border-b border-gray-100 dark:border-white/5 text-[10px] uppercase tracking-[0.2em] font-black text-gray-500">
                        <th class="px-6 py-5 text-center w-12"><input type="checkbox" id="select-all" class="w-4 h-4 rounded border-gray-300 dark:border-gray-700 bg-white dark:bg-background-dark text-primary focus:ring-primary" /></th>
                        <th class="px-6 py-5">@Localizer["User"]</th>
                        <th class="px-6 py-5">@Localizer["CommentContent"]</th>
                        <th class="px-6 py-5">@Localizer["Movie"]</th>
                        <th class="px-6 py-5">@Localizer["Status"]</th>
                        <th class="px-6 py-5 text-right pr-10">@Localizer["Actions"]</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 dark:divide-white/5 text-gray-700 dark:text-gray-300">
                    @if (Model.Items != null && Model.Items.Any())
                    {
                        @foreach (var comment in Model.Items)
                        {
                            string badgeClass;
                            string badgeText;

                            if (comment.Status == CommentStatus.Pending)
                            {
                                badgeClass = "bg-yellow-500/10 text-yellow-600 border border-yellow-500/20";
                                badgeText = Localizer["PendingStatus"];
                            }
                            else if (comment.Status == CommentStatus.Approved)
                            {
                                badgeClass = "bg-green-500/10 text-green-600 border border-green-500/20";
                                badgeText = Localizer["ApprovedStatus"];
                            }
                            else if (comment.Status == CommentStatus.Rejected)
                            {
                                badgeClass = "bg-orange-500/10 text-orange-600 border border-orange-500/20";
                                badgeText = Localizer["RejectedStatus"];
                            }
                            else
                            {
                                badgeClass = "bg-gray-500/10 text-gray-600 border border-gray-500/20";
                                badgeText = "";
                            }

                            <tr class="hover:bg-gray-50 dark:hover:bg-white/[0.02] transition-colors group comment-row" data-id="@comment.CommentId">
                                <td class="px-6 py-5 text-center">
                                    <input type="checkbox" name="selectedComments" value="@comment.CommentId" class="comment-checkbox w-4 h-4 rounded border-gray-300 dark:border-gray-700 bg-white dark:bg-background-dark text-primary" />
                                    <input type="hidden" class="movie-id-for-@comment.CommentId" value="@comment.MovieId" />
                                </td>
                                <td class="px-6 py-5">
                                    <div class="flex items-center gap-3">
                                        <img src="@(string.IsNullOrEmpty(comment.UserProfileImageUrl) ? "/profile-images/default-profile.png" : comment.UserProfileImageUrl)"
                                             onerror="this.src='/profile-images/default-profile.png';"
                                             class="h-10 w-10 rounded-full object-cover ring-2 ring-primary/20" />
                                        <div class="flex flex-col">
                                            <span class="text-sm font-bold text-gray-900 dark:text-white">@comment.Username</span>
                                            <span class="text-[9px] text-gray-400 font-mono">@comment.UserId.ToString().Substring(0, 8)</span>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-5 max-w-sm"><p class="text-sm line-clamp-2 leading-relaxed">@comment.Content</p></td>
                                <td class="px-6 py-5">
                                    <span class="text-[10px] font-black text-primary bg-primary/10 px-2.5 py-1 rounded-lg border border-primary/20">@comment.MovieTitle</span>
                                </td>
                                <td class="px-6 py-5 status-cell">
                                    <span class="@badgeClass text-[10px] font-black uppercase tracking-widest px-3 py-1 rounded-full border border-current/20">
                                        @badgeText
                                    </span>
                                </td>
                                <td class="px-6 py-5 text-right pr-10">
                                    <div class="flex justify-end gap-2 actions-container">
                                        @if (comment.Status == CommentStatus.Pending)
                                        {
                                            <button onclick="openConfirmModal(false, 'approve', '@comment.CommentId', '@comment.MovieId')"
                                                    class="action-btn p-2 bg-green-500/10 text-green-600 dark:text-green-500 hover:bg-green-600 hover:text-white rounded-xl transition-all border border-green-500/20"
                                                    title="@Localizer["Approve"]">
                                                <span class="material-icons-outlined text-lg">done</span>
                                            </button>
                                            <button onclick="openConfirmModal(false, 'reject', '@comment.CommentId', '@comment.MovieId')"
                                                    class="action-btn p-2 bg-orange-500/10 text-orange-600 dark:text-orange-500 hover:bg-orange-600 hover:text-white rounded-xl transition-all border border-orange-500/20"
                                                    title="@Localizer["Reject"]">
                                                <span class="material-icons-outlined text-lg">close</span>
                                            </button>
                                        }
                                        <button onclick="openConfirmModal(false, 'delete', '@comment.CommentId', '@comment.MovieId')"
                                                class="p-2 bg-red-500/10 text-red-600 dark:text-red-500 hover:bg-red-600 hover:text-white rounded-xl transition-all border border-red-500/20"
                                                title="@Localizer["Delete"]">
                                            <span class="material-icons-outlined text-lg">delete_outline</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="px-6 py-10 text-center text-gray-500 dark:text-gray-400">@Localizer["NoCommentsFound"]</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="flex justify-center items-center gap-3 mt-8">
            <a asp-action="Index" asp-route-pageNumber="@(Model.PageNumber - 1)" asp-route-searchTerm="@searchTerm" asp-route-status="@selectedStatus"
                   class="p-2.5 rounded-2xl bg-white dark:bg-surface-dark border border-gray-200 dark:border-white/5 text-gray-500 hover:text-primary transition-all @(!Model.HasPreviousPage ? "opacity-20 pointer-events-none" : "") shadow-sm">
                <span class="material-icons-outlined">west</span>
            </a>
            <div class="flex items-center gap-2">
                @{
                    int maxVisiblePages = 5;
                    int startPage = Math.Max(1, Model.PageNumber - (maxVisiblePages / 2));
                    int endPage = Math.Min(Model.TotalPages, startPage + maxVisiblePages - 1);
                    if (endPage - startPage + 1 < maxVisiblePages)
                    {
                        startPage = Math.Max(1, endPage - maxVisiblePages + 1);
                    }
                }
                @if (startPage > 1)
                {
                    <a asp-action="Index" asp-route-pageNumber="1" asp-route-searchTerm="@searchTerm" asp-route-status="@selectedStatus"
                       class="w-11 h-11 flex items-center justify-center rounded-2xl font-black transition-all bg-white dark:bg-surface-dark border border-gray-200 dark:border-white/5 text-gray-500 hover:text-primary">1</a>
                    @if (startPage > 2)
                    {
                        <span class="text-gray-400 font-bold px-2">...</span>
                    }
                }
                @for (int i = startPage; i <= endPage; i++)
                {
                    <a asp-action="Index" asp-route-pageNumber="@i" asp-route-searchTerm="@searchTerm" asp-route-status="@selectedStatus"
                           class="w-11 h-11 flex items-center justify-center rounded-2xl font-black transition-all @(Model.PageNumber == i ? "bg-primary text-white shadow-xl shadow-primary/40 scale-110" : "bg-white dark:bg-surface-dark border border-gray-200 dark:border-white/5 text-gray-500 hover:text-primary")">
                        @i
                    </a>
                }
                @if (endPage < Model.TotalPages)
                {
                    @if (endPage < Model.TotalPages - 1)
                    {
                        <span class="text-gray-400 font-bold px-2">...</span>
                    }
                    <a asp-action="Index" asp-route-pageNumber="@Model.TotalPages" asp-route-searchTerm="@searchTerm" asp-route-status="@selectedStatus"
                       class="w-11 h-11 flex items-center justify-center rounded-2xl font-black transition-all bg-white dark:bg-surface-dark border border-gray-200 dark:border-white/5 text-gray-500 hover:text-primary">@Model.TotalPages</a>
                }
            </div>
            <a asp-action="Index" asp-route-pageNumber="@(Model.PageNumber + 1)" asp-route-searchTerm="@searchTerm" asp-route-status="@selectedStatus"
                   class="p-2.5 rounded-2xl bg-white dark:bg-surface-dark border border-gray-200 dark:border-white/5 text-gray-500 hover:text-primary transition-all @(!Model.HasNextPage ? "opacity-20 pointer-events-none" : "") shadow-sm">
                <span class="material-icons-outlined">east</span>
            </a>
        </div>
    }
</div>

<div id="confirmModal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4 backdrop-blur-xl bg-black/60">
    <div class="bg-white dark:bg-surface-dark border border-gray-200 dark:border-white/10 w-full max-w-md rounded-[2.5rem] p-10 shadow-2xl transform transition-all scale-95 opacity-0 duration-300" id="modalContainer">
        <div class="text-center">
            <div id="modalIconBg" class="w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6">
                <span id="modalIcon" class="material-icons-outlined text-4xl text-white">help_outline</span>
            </div>
            <h3 id="modalTitle" class="text-2xl font-black text-gray-900 dark:text-white mb-2 tracking-tight"></h3>
            <p id="modalDesc" class="text-gray-500 dark:text-gray-400 text-sm px-4 mb-8 leading-relaxed"></p>
            <div class="flex gap-4">
                <button onclick="closeConfirmModal()" class="flex-1 py-4 bg-gray-100 dark:bg-white/5 text-gray-600 dark:text-gray-400 font-bold rounded-2xl hover:bg-gray-200 dark:hover:bg-white/10 transition-all">@Localizer["Cancel"]</button>
                <button id="modalConfirmBtn" class="flex-1 py-4 text-white font-bold rounded-2xl transition-all shadow-lg"></button>
            </div>
        </div>
    </div>
</div>

<form id="antiForgeryForm">@Html.AntiForgeryToken()</form>

@section Scripts {
    <script>
        window.localizedStrings = {
        bulkDeleteTitle: "@Html.Raw(Localizer["BulkDeleteTitle"])",
        singleDeleteTitle: "@Html.Raw(Localizer["SingleDeleteTitle"])",
        deleteWarning: "@Html.Raw(Localizer["DeleteWarning"])",
        yesDelete: "@Html.Raw(Localizer["YesDelete"])",
        bulkApproveTitle: "@Html.Raw(Localizer["BulkApproveTitle"])",
        approveTitle: "@Html.Raw(Localizer["ApproveTitle"])",
        rejectTitle: "@Html.Raw(Localizer["RejectTitle"])",
        approveDescription: "@Html.Raw(Localizer["ApproveDescription"])",
        yesApprove: "@Html.Raw(Localizer["YesApprove"])",
        bulkRejectTitle: "@Html.Raw(Localizer["BulkRejectTitle"])",
        rejectDescription: "@Html.Raw(Localizer["RejectDescription"])",
        yesReject: "@Html.Raw(Localizer["YesReject"])",
        approvedStatus: "@Html.Raw(Localizer["ApprovedStatus"])",
        rejectedStatus: "@Html.Raw(Localizer["RejectedStatus"])",
        deleteTitleForBtn: "@Html.Raw(Localizer["DeleteTitleForBtn"])"
            
        };
    </script>
    <script src="~/js/admincomment/admincomment.js"></script>
}