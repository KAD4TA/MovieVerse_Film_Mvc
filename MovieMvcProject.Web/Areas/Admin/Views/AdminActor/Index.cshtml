@model MovieMvcProject.Application.Commons.PagedResult<MovieMvcProject.Web.Models.ActorListViewModel>
@using MovieMvcProject.Application.Commons
@using MovieMvcProject.Web.Areas.Admin.Resources
@inject Microsoft.Extensions.Localization.IStringLocalizer<AdminActorDirectorResource> ActorLocalizer
@inject Microsoft.Extensions.Localization.IStringLocalizer<MovieMvcProject.Domain.Resources.MenuResource> MenuLocalizer
@{
    ViewData["Title"] = ActorLocalizer["List.Title"];
    Layout = "_LayoutAdmin";
    var totalItems = Model?.TotalCount ?? 0;
    var pageSize = Model?.PageSize ?? 10;
    var currentPage = Model?.PageNumber ?? 1;
    var totalPages = Model?.TotalPages ?? 1;
    var hasPreviousPage = Model?.HasPreviousPage ?? false;
    var hasNextPage = Model?.HasNextPage ?? false;
    var searchTerm = ViewBag.SearchTerm as string ?? "";
    int spread = 2;
    int startPage = Math.Max(1, currentPage - spread);
    int endPage = Math.Min(totalPages, currentPage + spread);
}

@section Styles {
    <link rel="stylesheet" href="~/css/adminactor/actor-custom.css" />
}

<div class="p-8 flex flex-col gap-8 w-full max-w-[1920px] mx-auto transition-colors duration-300">
    @if (TempData["Success"] != null)
    {
        <div class="flex items-center p-4 rounded-2xl bg-green-500/10 border border-green-500/20 shadow-[0_0_15px_rgba(16,185,129,0.1)] animate-fade-in text-green-600 dark:text-green-400" role="alert">
            <span class="material-icons-outlined mr-3 text-xl">check_circle</span>
            <div class="text-sm font-bold">@TempData["Success"]</div>
        </div>
    }
    
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
        <div>
            <h1 class="text-3xl font-black text-gray-900 dark:text-white tracking-tight flex items-center gap-3">
                <span class="w-2 h-8 bg-primary rounded-full shadow-[0_0_10px_rgba(139,92,246,0.5)]"></span>
                @ActorLocalizer["List.AllActors"]
            </h1>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-2 font-medium pl-5">
                @ActorLocalizer["List.TotalFound"]: <span class="text-gray-900 dark:text-white">@totalItems</span>
            </p>
        </div>
        <div class="flex flex-col sm:flex-row items-center gap-4 w-full md:w-auto">
            <form asp-area="Admin" asp-controller="AdminActor" asp-action="Index" method="get" class="w-full sm:w-auto flex-1">
                <div class="relative group">
                    <input type="search" name="searchTerm" value="@searchTerm" placeholder="@ActorLocalizer["List.SearchPlaceholder"]"
                           class="w-full sm:w-72 pl-11 pr-4 py-2.5 rounded-xl bg-white dark:bg-surface-dark border border-gray-200 dark:border-white/10 text-gray-900 dark:text-gray-200 focus:ring-2 focus:ring-primary/50 outline-none text-sm transition-all shadow-sm" />
                    <span class="material-icons-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">search</span>
                </div>
            </form>
            <a asp-area="Admin" asp-controller="AdminActor" asp-action="Create"
                   class="w-full sm:w-auto px-6 py-2.5 rounded-xl bg-primary text-white font-bold text-sm shadow-lg hover:scale-105 active:scale-95 transition-all flex items-center justify-center gap-2">
                <span class="material-icons-outlined text-lg">add_circle</span>
                @ActorLocalizer["List.AddNew"]
            </a>
        </div>
    </div>
    
    <div class="bg-white dark:bg-surface-dark rounded-3xl border border-gray-200 dark:border-white/5 shadow-xl overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full text-left">
                <thead>
                    <tr class="border-b border-gray-100 dark:border-white/5 bg-gray-50 dark:bg-black/20">
                        <th class="px-6 py-5 text-xs font-black text-gray-400 uppercase">@ActorLocalizer["List.Profile"]</th>
                        <th class="px-6 py-5 text-xs font-black text-gray-400 uppercase">@ActorLocalizer["List.Name"]</th>
                        <th class="px-6 py-5 text-xs font-black text-gray-400 uppercase text-center">@ActorLocalizer["List.BirthDate"]</th>
                        <th class="px-6 py-5 text-xs font-black text-gray-400 uppercase text-center">@ActorLocalizer["List.MovieCount"]</th>
                        <th class="px-6 py-5 text-xs font-black text-gray-400 uppercase text-right">@ActorLocalizer["List.Actions"]</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 dark:divide-white/5">
                    @if (Model?.Items != null && Model.Items.Any())
                    {
                        @foreach (var actor in Model.Items)
                        {
                            <tr class="group hover:bg-gray-50 dark:hover:bg-white/5 transition-colors">
                                <td class="px-6 py-4 w-20">
                                    <img class="w-12 h-12 rounded-full object-cover border border-gray-200 dark:border-white/10"
                                         src="@(string.IsNullOrEmpty(actor.AvatarUrl) ? "/profile-images/default-profile.png" : actor.AvatarUrl)"
                                         onerror="this.src='/images/default-avatar.jpg';">
                                </td>
                                <td class="px-6 py-4">
                                    <div class="font-bold text-gray-900 dark:text-gray-200 text-sm">@actor.Name</div>
                                    <div class="text-[10px] text-gray-400 font-mono">ID: #@actor.ActorId?.ToString().Substring(0, 8)</div>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <span class="text-sm font-medium text-gray-600 dark:text-gray-400 bg-gray-100 dark:bg-white/5 px-2 py-1 rounded">
                                        @(actor.BirthDate?.ToShortDateString() ?? "N/A")
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    @{
                                        var movieColor = actor.MovieCount >= 10 ? "text-green-600 bg-green-500/10" : "text-yellow-600 bg-yellow-500/10";
                                    }
                                    <div class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg font-bold text-sm @movieColor">
                                        <span class="material-icons-outlined text-sm">movie</span> @actor.MovieCount
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        <a asp-area="Admin" asp-controller="AdminActor" asp-action="Edit" asp-route-id="@actor.ActorId"
                                               class="w-8 h-8 flex items-center justify-center rounded-lg bg-gray-100 dark:bg-white/5 text-blue-600 hover:bg-blue-600 hover:text-white transition-all">
                                            <span class="material-icons-outlined text-base">edit</span>
                                        </a>
                                        <button type="button" onclick="openDeleteModal('@actor.ActorId', '@actor.Name', '@actor.AvatarUrl', '@actor.BirthDate?.ToShortDateString()', '@actor.MovieCount')"
                                                class="w-8 h-8 flex items-center justify-center rounded-lg bg-gray-100 dark:bg-white/5 text-red-600 hover:bg-red-600 hover:text-white transition-all">
                                            <span class="material-icons-outlined text-base">delete</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5" class="text-center py-12 text-slate-400">@ActorLocalizer["List.NoData"]</td></tr>
                    }
                </tbody>
            </table>
        </div>
        
        <div class="px-6 py-5 border-t border-gray-100 dark:border-white/5 bg-gray-50 dark:bg-black/20 flex flex-col sm:flex-row items-center justify-between gap-4">
            <span class="text-xs text-gray-500 font-medium">
                @ActorLocalizer["List.Page"] <span class="text-gray-900 dark:text-white">@currentPage</span> / @totalPages
            </span>
            <nav class="flex items-center gap-2">
                <a asp-area="Admin" asp-controller="AdminActor" asp-action="Index"
                       asp-route-pageNumber="@(currentPage - 1)" asp-route-searchTerm="@searchTerm" asp-route-pageSize="@pageSize"
                       class="w-9 h-9 flex items-center justify-center rounded-lg bg-white dark:bg-surface-dark border border-gray-200 dark:border-white/10 text-gray-400 hover:text-primary transition-all @(!hasPreviousPage ? "opacity-30 pointer-events-none" : "")">
                    <span class="material-icons-outlined text-lg">chevron_left</span>
                </a>
                @for (int i = startPage; i <= endPage; i++)
                {
                    <a asp-area="Admin" asp-controller="AdminActor" asp-action="Index"
                           asp-route-pageNumber="@i" asp-route-searchTerm="@searchTerm" asp-route-pageSize="@pageSize"
                           class="w-9 h-9 flex items-center justify-center rounded-lg text-sm font-bold border transition-all @(i == currentPage ? "bg-primary border-primary text-white shadow-lg" : "bg-white dark:bg-surface-dark border-gray-200 dark:border-white/10 text-gray-400 hover:bg-gray-50")">
                        @i
                    </a>
                }
                <a asp-area="Admin" asp-controller="AdminActor" asp-action="Index"
                       asp-route-pageNumber="@(currentPage + 1)" asp-route-searchTerm="@searchTerm" asp-route-pageSize="@pageSize"
                       class="w-9 h-9 flex items-center justify-center rounded-lg bg-white dark:bg-surface-dark border border-gray-200 dark:border-white/10 text-gray-400 hover:text-primary transition-all @(!hasNextPage ? "opacity-30 pointer-events-none" : "")">
                    <span class="material-icons-outlined text-lg">chevron_right</span>
                </a>
            </nav>
        </div>
    </div>
</div>

@* Modal Partial Çağrısı *@
<partial name="AdminActor/_DeleteActorModalPartial" />

@section Scripts {
    <script src="~/js/adminactor/actor-list.js"></script>
}