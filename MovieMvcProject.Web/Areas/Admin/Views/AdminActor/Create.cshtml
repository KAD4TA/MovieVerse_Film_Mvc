@using MovieMvcProject.Web.Areas.Admin.Models
@using MovieMvcProject.Web.Areas.Admin.Resources
@model CreateActorViewModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<AdminActorDirectorResource> ActorLocalizer
@{
    ViewData["Title"] = ActorLocalizer["Create.Title"];
    Layout = "_LayoutAdmin";
}
<div class="p-8 max-w-2xl mx-auto">
    <div class="bg-white dark:bg-surface-dark rounded-3xl shadow-xl p-8">
        <h1 class="text-3xl font-black mb-8 flex items-center gap-3">
            <span class="material-icons-outlined text-primary">person_add</span>
            @ActorLocalizer["Create.Header"]
        </h1>
        <form asp-action="Create" method="post" class="space-y-6">
            @Html.AntiForgeryToken()
            <div>
                <label class="block text-sm font-medium mb-1">@ActorLocalizer["Create.NameLabel"]</label>
                <input asp-for="Name" class="w-full px-4 py-3 rounded-2xl border border-gray-200 dark:border-white/10 focus:ring-2 focus:ring-primary bg-gray-50 text-gray-900 dark:bg-white/5 dark:text-white" />
                <span asp-validation-for="Name" class="text-red-500 text-sm"></span>
            </div>
            <div>
                <label class="block text-sm font-medium mb-1">@ActorLocalizer["Create.PhotoUrlLabel"]</label>
                <input asp-for="PhotoUrl" class="w-full px-4 py-3 rounded-2xl border border-gray-200 dark:border-white/10 bg-gray-50 text-gray-900 dark:bg-white/5 dark:text-white" placeholder="https://..." />
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-medium mb-1">@ActorLocalizer["Create.BirthDateLabel"]</label>
                    <input asp-for="BirthDate" type="date" class="w-full px-4 py-3 rounded-2xl border border-gray-200 dark:border-white/10 bg-gray-50 text-gray-900 dark:bg-white/5 dark:text-white" />
                </div>
                <div>
                    <label class="block text-sm font-medium mb-1">@ActorLocalizer["Create.BirthPlaceLabel"]</label>
                    <input asp-for="BirthPlace" class="w-full px-4 py-3 rounded-2xl border border-gray-200 dark:border-white/10 bg-gray-50 text-gray-900 dark:bg-white/5 dark:text-white" />
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium mb-1">@ActorLocalizer["Create.HeightLabel"]</label>
                <input asp-for="Height" type="number"
                       class="w-full px-4 py-3 rounded-2xl border border-gray-200 dark:border-white/10 bg-gray-50 text-gray-900 dark:bg-white/5 dark:text-white" />
            </div>
            <div class="flex gap-4 pt-6">
                <button type="submit" class="flex-1 bg-primary hover:bg-primary/90 text-white font-bold py-4 rounded-2xl transition-all">
                    @ActorLocalizer["Create.SaveButton"]
                </button>
                <a asp-action="Index" class="flex-1 text-center border border-gray-300 dark:border-white/10 font-bold py-4 rounded-2xl hover:bg-gray-50 dark:hover:bg-white/5">
                    @ActorLocalizer["Create.CancelButton"]
                </a>
            </div>
        </form>
    </div>
</div>